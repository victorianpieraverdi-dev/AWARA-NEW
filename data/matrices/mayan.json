{
  "matrix_slug": "mayan",
  "matrix_name": "\u041c\u0430\u0439\u044f\u043d\u0441\u043a\u0430\u044f",
  "element_accent": "\u0417\u0435\u043c\u043b\u044f",
  "chakra_accent": "\u0410\u0434\u0436\u043d\u0430",
  "guna_accent": "\u0440\u0430\u0434\u0436\u0430\u0441",
  "graha_accent": "\u0421\u043e\u043b\u043d\u0446\u0435",
  "pole": {
    "toward": "\u0421\u0432\u044f\u0449\u0435\u043d\u043d\u044b\u0439 \u0441\u0447\u0451\u0442 (\u0426\u043e\u043b\u044c\u043a\u0438\u043d) \u2014 \u0436\u0438\u0437\u043d\u044c \u0432 \u0441\u043e\u0433\u043b\u0430\u0441\u0438\u0438 \u0441 \u0440\u0438\u0442\u043c\u043e\u043c \u0434\u043d\u0435\u0439, \u0433\u0430\u0440\u043c\u043e\u043d\u0438\u044f \u0447\u0435\u043b\u043e\u0432\u0435\u043a\u0430, \u0432\u0440\u0435\u043c\u0435\u043d\u0438 \u0438 \u043a\u043e\u0441\u043c\u043e\u0441\u0430",
    "away": "\u0421\u043b\u043e\u043c\u0430\u043d\u043d\u044b\u0439 \u0441\u0447\u0451\u0442 \u2014 \u043f\u043e\u0442\u0435\u0440\u044f \u0440\u0438\u0442\u043c\u0430, \u0440\u0430\u0437\u0440\u044b\u0432 \u0441 \u043a\u0430\u043b\u0435\u043d\u0434\u0430\u0440\u0451\u043c \u0438 \u043a\u043e\u0441\u043c\u0438\u0447\u0435\u0441\u043a\u0438\u043c \u043f\u043e\u0440\u044f\u0434\u043a\u043e\u043c, \u0445\u0430\u043e\u0441 \u0432\u0440\u0435\u043c\u0435\u043d\u0438",
    "note": "\u0421\u0432\u0435\u0442 \u2014 \u0447\u0438\u0442\u0430\u0442\u044c \u0437\u043d\u0430\u043a\u0438 \u0434\u043d\u0435\u0439 \u0438 \u0438\u0434\u0442\u0438 \u0432 \u0440\u0438\u0442\u043c\u0435 \u0426\u043e\u043b\u044c\u043a\u0438\u043d\u0430; \u0442\u0435\u043d\u044c \u2014 \u0432\u044b\u043f\u0430\u0441\u0442\u044c \u0438\u0437 \u0441\u0447\u0451\u0442\u0430, \u0443\u0442\u0440\u0430\u0442\u0438\u0442\u044c \u0441\u0432\u044f\u0437\u044c \u0441\u043e \u0432\u0440\u0435\u043c\u0435\u043d\u0435\u043c \u0438 \u043f\u0440\u0435\u0434\u043a\u0430\u043c\u0438"
  },
  "core": "\u041b\u0438\u043d\u0437\u0430 \u0421\u0432\u044f\u0449\u0435\u043d\u043d\u043e\u0433\u043e \u0438 \u0421\u043b\u043e\u043c\u0430\u043d\u043d\u043e\u0433\u043e \u0441\u0447\u0451\u0442\u0430: \u043c\u0438\u0440 \u2014 \u0436\u0438\u0432\u043e\u0439 \u043a\u0430\u043b\u0435\u043d\u0434\u0430\u0440\u044c \u0434\u043d\u0435\u0439-\u0441\u0443\u0434\u0435\u0431; \u0432\u043e\u0441\u0445\u043e\u0436\u0434\u0435\u043d\u0438\u0435 \u2014 \u0432\u043e\u0439\u0442\u0438 \u0432 \u0440\u0438\u0442\u043c \u0426\u043e\u043b\u044c\u043a\u0438\u043d\u0430 \u0438 \u0441\u043f\u043b\u0435\u0441\u0442\u0438 \u0441\u0432\u043e\u0439 \u043a\u0438\u043d \u0441 \u043a\u043e\u0441\u043c\u0438\u0447\u0435\u0441\u043a\u0438\u043c \u043f\u043e\u0440\u044f\u0434\u043a\u043e\u043c.",
  "faces": {
    "svet_ra": "\u041a\u0438\u043d\u0438\u0447 \u0410\u0445\u0430\u0443 \u2014 \u0441\u043e\u043b\u043d\u0435\u0447\u043d\u044b\u0439 \u043b\u0438\u043a, \u0438\u0441\u0442\u043e\u0447\u043d\u0438\u043a \u0434\u043d\u044f \u0438 \u0441\u0432\u0435\u0442\u0430",
    "iskra": "\u0427\u0430\u043a-\u042d\u043a (\u0412\u0435\u043d\u0435\u0440\u0430) \u2014 \u0443\u0442\u0440\u0435\u043d\u043d\u044f\u044f \u0437\u0432\u0435\u0437\u0434\u0430, \u0437\u043e\u0432 \u0438 \u0438\u0441\u043a\u0440\u0430 \u043f\u0440\u043e\u0431\u0443\u0436\u0434\u0435\u043d\u0438\u044f",
    "brahma": "\u041a\u0443\u043a\u0443\u043b\u044c\u043a\u0430\u043d \u2014 \u043f\u0435\u0440\u043d\u0430\u0442\u044b\u0439 \u0437\u043c\u0435\u0439, \u0442\u0432\u043e\u0440\u0435\u0446 \u0444\u043e\u0440\u043c \u0438 \u0446\u0438\u043a\u043b\u043e\u0432",
    "sarasvati": "\u0418\u0446\u0430\u043c\u043d\u0430 \u2014 \u043c\u0443\u0434\u0440\u043e\u0441\u0442\u044c, \u043f\u0438\u0441\u044c\u043c\u043e, \u0441\u043b\u043e\u0432\u043e \u0438 \u0437\u043d\u0430\u043d\u0438\u0435",
    "vishnu": "\u0425\u0443\u043d-\u0425\u0443\u043d\u0430\u0445\u043f\u0443 \u2014 \u0431\u043e\u0433 \u043c\u0430\u0438\u0441\u0430, \u043f\u043e\u0434\u0434\u0435\u0440\u0436\u0430\u043d\u0438\u0435 \u0438 \u0432\u043e\u0437\u0440\u043e\u0436\u0434\u0435\u043d\u0438\u0435 \u0436\u0438\u0437\u043d\u0438",
    "lakshmi": "\u0419\u0443\u043c-\u041a\u0430\u0430\u0448 \u2014 \u0432\u043b\u0430\u0434\u044b\u043a\u0430 \u043b\u0435\u0441\u0430 \u0438 \u0443\u0440\u043e\u0436\u0430\u044f, \u0438\u0437\u043e\u0431\u0438\u043b\u0438\u0435 \u0437\u0435\u043c\u043b\u0438",
    "shiva": "\u0410\u0445-\u041f\u0443\u0447 \u2014 \u0432\u043b\u0430\u0434\u044b\u043a\u0430 \u0441\u043c\u0435\u0440\u0442\u0438 \u0438 \u0440\u0430\u0437\u043b\u043e\u0436\u0435\u043d\u0438\u044f, \u0440\u0430\u0437\u0440\u0443\u0448\u0435\u043d\u0438\u0435",
    "parvati": "\u0428\u043a\u0438\u043a \u2014 \u043c\u0430\u0442\u044c \u0413\u0435\u0440\u043e\u0435\u0432-\u0411\u043b\u0438\u0437\u043d\u0435\u0446\u043e\u0432, \u0437\u0430\u0431\u043e\u0442\u0430 \u0438 \u0440\u043e\u0436\u0434\u0435\u043d\u0438\u0435",
    "jnana": "\u0410\u0445-\u041a\u0438\u043d \u2014 \u0436\u0440\u0435\u0446-\u0441\u0447\u0451\u0442\u0447\u0438\u043a \u0434\u043d\u0435\u0439, \u0440\u0430\u0437\u043b\u0438\u0447\u0435\u043d\u0438\u0435 \u0437\u043d\u0430\u043a\u043e\u0432",
    "prema": "\u0418\u0448-\u0427\u0435\u043b\u044c \u2014 \u043b\u0443\u043d\u043d\u0430\u044f \u043c\u0430\u0442\u044c, \u043b\u044e\u0431\u043e\u0432\u044c, \u0442\u043a\u0430\u0447\u0435\u0441\u0442\u0432\u043e \u0441\u043e\u044e\u0437\u043e\u0432 \u0438 \u043f\u043b\u043e\u0434\u043e\u0440\u043e\u0434\u0438\u0435",
    "shakti": "\u041a'\u0430\u0432\u0438\u0438\u043b\u044c \u2014 \u043c\u043e\u043b\u043d\u0438\u044f, \u0441\u0438\u043b\u0430, \u043c\u043e\u0449\u044c \u0438 \u0432\u043b\u0430\u0441\u0442\u044c \u043b\u0438\u043d\u0438\u0438",
    "ananda": "\u0425\u0443\u043d\u0430\u0445\u043f\u0443 \u2014 \u0433\u0435\u0440\u043e\u0439-\u0431\u043b\u0438\u0437\u043d\u0435\u0446, \u0432\u043e\u0441\u0445\u043e\u0434\u044f\u0449\u0435\u0435 \u0431\u043b\u0430\u0436\u0435\u043d\u0441\u0442\u0432\u043e \u0441\u043e\u043b\u043d\u0446\u0430",
    "shanti": "\u0428\u0431\u0430\u043b\u0430\u043d\u043a\u0435 \u2014 \u0433\u0435\u0440\u043e\u0439-\u0431\u043b\u0438\u0437\u043d\u0435\u0446, \u043b\u0443\u043d\u043d\u044b\u0439 \u043f\u043e\u043a\u043e\u0439 \u043d\u043e\u0447\u0438",
    "agni": "\u041a'\u0430\u043a' \u2014 \u0441\u0432\u044f\u0449\u0435\u043d\u043d\u044b\u0439 \u043e\u0433\u043e\u043d\u044c \u0436\u0435\u0440\u0442\u0432\u044b \u0438 \u043e\u0431\u043d\u043e\u0432\u043b\u0435\u043d\u0438\u044f",
    "vayu": "\u0418\u043a' \u2014 \u0432\u0435\u0442\u0435\u0440, \u0434\u044b\u0445\u0430\u043d\u0438\u0435 \u0438 \u0434\u0443\u0445",
    "varuna": "\u0428\u0438\u0431\u0430\u043b\u044c\u0431\u0430 \u2014 \u043f\u043e\u0434\u0437\u0435\u043c\u043d\u044b\u0435 \u0432\u043e\u0434\u044b, \u0433\u043b\u0443\u0431\u0438\u043d\u0430 \u0438 \u043f\u0430\u043c\u044f\u0442\u044c \u043f\u0440\u0435\u0434\u043a\u043e\u0432",
    "prithvi": "\u0411\u0430\u043a\u0430\u0431\u044b \u2014 \u0447\u0435\u0442\u044b\u0440\u0435 \u0434\u0435\u0440\u0436\u0430\u0442\u0435\u043b\u044f \u0437\u0435\u043c\u043b\u0438 \u0438 \u043d\u0435\u0431\u0430, \u043e\u043f\u043e\u0440\u0430",
    "akasha": "\u0421\u0435\u0440\u0434\u0446\u0435 \u041d\u0435\u0431\u0435\u0441 (\u0425\u0443\u0440\u0430\u043a\u0430\u043d) \u2014 \u043f\u0440\u043e\u0441\u0442\u0440\u0430\u043d\u0441\u0442\u0432\u043e \u0438 \u0434\u044b\u0445\u0430\u043d\u0438\u0435 \u043d\u0435\u0431\u0430",
    "tejas": "\u041a\u0438\u043d\u0438\u0447-\u041a\u0430\u043a\u043c\u043e \u2014 \u043e\u0433\u043d\u0435\u043d\u043d\u044b\u0439 \u0430\u0440\u0430, \u0441\u0438\u044f\u043d\u0438\u0435 \u0441\u043e\u043b\u043d\u0435\u0447\u043d\u043e\u0433\u043e \u0431\u043b\u0435\u0441\u043a\u0430",
    "dharma": "\u0425\u0430\u0430\u0431 \u0438 \u0426\u043e\u043b\u044c\u043a\u0438\u043d \u2014 \u0441\u0432\u044f\u0449\u0435\u043d\u043d\u044b\u0439 \u0437\u0430\u043a\u043e\u043d \u0432\u0440\u0435\u043c\u0435\u043d\u0438 \u0438 \u0434\u043e\u043b\u0433 \u043f\u043e\u0440\u044f\u0434\u043a\u0430",
    "karma": "\u041a\u0430\u043b\u0435\u043d\u0434\u0430\u0440\u043d\u044b\u0439 \u041a\u0440\u0443\u0433 \u2014 \u0441\u043f\u043b\u0435\u0442\u0435\u043d\u0438\u0435 \u043f\u0440\u0438\u0447\u0438\u043d \u0438 \u0441\u043b\u0435\u0434\u0441\u0442\u0432\u0438\u0439, \u0432\u043e\u0437\u0434\u0430\u044f\u043d\u0438\u0435 \u0441\u0443\u0434\u044c\u0431\u044b"
  },
  "resonance_keywords": ["\u0426\u043e\u043b\u044c\u043a\u0438\u043d", "\u041a\u0438\u043d", "\u041f\u043e\u043f\u043e\u043b\u044c-\u0412\u0443\u0445", "\u041a\u0443\u043a\u0443\u043b\u044c\u043a\u0430\u043d", "\u0428\u0438\u0431\u0430\u043b\u044c\u0431\u0430", "\u0411\u0430\u043a\u0430\u0431\u044b", "\u0421\u0435\u0440\u0434\u0446\u0435 \u041d\u0435\u0431\u0435\u0441", "\u043c\u0430\u0438\u0441", "\u0413\u0435\u0440\u043e\u0438-\u0411\u043b\u0438\u0437\u043d\u0435\u0446\u044b", "\u043d\u0435\u0444\u0440\u0438\u0442"],
  "visual_code": "\u043d\u0435\u0444\u0440\u0438\u0442\u043e\u0432\u044b\u0435 \u043c\u0430\u0441\u043a\u0438, \u043a\u043e\u043b\u0435\u0441\u043e \u0426\u043e\u043b\u044c\u043a\u0438\u043d\u0430 \u0438\u0437 260 \u0434\u043d\u0435\u0439, \u043f\u0435\u0440\u043d\u0430\u0442\u044b\u0439 \u0437\u043c\u0435\u0439, \u0441\u0442\u0443\u043f\u0435\u043d\u0447\u0430\u0442\u044b\u0435 \u043f\u0438\u0440\u0430\u043c\u0438\u0434\u044b, \u0438\u0435\u0440\u043e\u0433\u043b\u0438\u0444\u044b-\u0433\u043b\u0438\u0444\u044b, \u0437\u0435\u043b\u0451\u043d\u044b\u0435 \u043f\u0435\u0440\u044c\u044f \u043a\u0435\u0442\u0446\u0430\u043b\u044f, \u043e\u0431\u0441\u0438\u0434\u0438\u0430\u043d \u0438 \u043a\u0430\u043a\u0430\u043e",
  "sources": ["https://en.wikipedia.org/wiki/Maya_civilization", "https://en.wikipedia.org/wiki/Maya_religion", "https://en.wikipedia.org/wiki/Tzolkin", "https://en.wikipedia.org/wiki/Popol_Vuh", "https://en.wikipedia.org/wiki/Kukulkan", "https://en.wikipedia.org/wiki/Maya_Hero_Twins"]
