  "pole": {
    "toward": "\u0425\u0430\u0440\u0430\u044d \u2014 \u043e\u0447\u0438\u0449\u0435\u043d\u0438\u0435, \u0432\u043e\u0441\u0441\u0442\u0430\u043d\u043e\u0432\u043b\u0435\u043d\u0438\u0435 \u0447\u0438\u0441\u0442\u043e\u0442\u044b \u0438 \u0436\u0438\u0432\u043e\u0439 \u0441\u0432\u044f\u0437\u0438 \u0441 \u043a\u0430\u043c\u0438",
    "away": "\u041a\u0435\u0433\u0430\u0440\u0435 \u2014 \u0441\u043a\u0432\u0435\u0440\u043d\u0430 \u0438 \u043e\u0441\u043a\u0432\u0435\u0440\u043d\u0435\u043d\u0438\u0435, \u0447\u0442\u043e \u0440\u0430\u0437\u0440\u044b\u0432\u0430\u0435\u0442 \u0441\u0432\u044f\u0437\u044c \u0441 \u043a\u0430\u043c\u0438",
    "note": "\u0421\u0432\u0435\u0442 \u2014 \u043e\u043c\u044b\u0442\u044c\u0441\u044f \u0432 \u043c\u0438\u0441\u043e\u0433\u0438 \u0438 \u0432\u0435\u0440\u043d\u0443\u0442\u044c \u0447\u0438\u0441\u0442\u043e\u0442\u0443 \u0441\u0432\u044f\u0437\u0438; \u0442\u0435\u043d\u044c \u2014 \u043a\u043e\u043f\u0438\u0442\u044c \u0441\u043a\u0432\u0435\u0440\u043d\u0443 \u0438 \u0433\u043b\u043e\u0445\u043d\u0443\u0442\u044c \u043a \u0437\u043e\u0432\u0443 \u043a\u0430\u043c\u0438"
  },
  "core": "\u041b\u0438\u043d\u0437\u0430 \u0425\u0430\u0440\u0430\u044d \u0438 \u041a\u0435\u0433\u0430\u0440\u0435: \u043c\u0438\u0440 \u0442\u043e \u0447\u0438\u0441\u0442, \u0442\u043e \u043e\u0441\u043a\u0432\u0435\u0440\u043d\u0451\u043d, \u0438 \u0447\u0435\u043b\u043e\u0432\u0435\u043a \u043c\u0438\u0441\u043e\u0433\u0438 \u043e\u0447\u0438\u0449\u0430\u0435\u0442 \u0441\u0435\u0431\u044f \u0438 \u043f\u0440\u043e\u0441\u0442\u0440\u0430\u043d\u0441\u0442\u0432\u043e; \u0432\u043e\u0441\u0445\u043e\u0436\u0434\u0435\u043d\u0438\u0435 \u2014 \u0436\u0438\u0442\u044c \u0432 \u043c\u0430\u043a\u043e\u0442\u043e \u0438 \u0441\u043e\u0433\u043b\u0430\u0441\u0438\u0438 \u0441 \u043a\u0430\u043c\u0438, \u0445\u0440\u0430\u043d\u044f \u0447\u0438\u0441\u0442\u043e\u0442\u0443 \u0442\u0435\u043b\u0430 \u0438 \u0441\u0435\u0440\u0434\u0446\u0430.",
  "faces": {
    "svet_ra": "\u0410\u043c\u0430\u0442\u044d\u0440\u0430\u0441\u0443 \u2014 \u0441\u043e\u043b\u043d\u0435\u0447\u043d\u0430\u044f \u0431\u043e\u0433\u0438\u043d\u044f, \u0438\u0441\u0442\u043e\u043a \u0441\u0432\u0435\u0442\u0430 \u0438 \u043d\u0435\u0431\u0435\u0441\u043d\u043e\u0433\u043e \u0440\u043e\u0434\u0430",
    "iskra": "\u0426\u0443\u043a\u0443\u0451\u043c\u0438 \u2014 \u043b\u0443\u043d\u043d\u044b\u0439 \u0431\u043e\u0433, \u0442\u0438\u0445\u0438\u0439 \u0437\u043e\u0432 \u043d\u043e\u0447\u0438",
    "brahma": "\u0418\u0434\u0437\u0430\u043d\u0430\u0433\u0438 \u0438 \u0418\u0434\u0437\u0430\u043d\u0430\u043c\u0438 \u2014 \u0442\u0432\u043e\u0440\u0446\u044b, \u0440\u043e\u0434\u0438\u0432\u0448\u0438\u0435 \u043e\u0441\u0442\u0440\u043e\u0432\u0430 \u0438 \u043c\u0438\u0440 \u0444\u043e\u0440\u043c",
    "sarasvati": "\u0410\u043c\u044d-\u043d\u043e-\u041a\u043e\u044f\u043d\u044d \u2014 \u0431\u043e\u0433 \u0441\u0432\u044f\u0449\u0435\u043d\u043d\u044b\u0445 \u0441\u043b\u043e\u0432 \u0438 \u043c\u043e\u043b\u0438\u0442\u0432 \u043d\u043e\u0440\u0438\u0442\u043e",
    "vishnu": "\u041e\u043a\u0443\u043d\u0438\u043d\u0443\u0441\u0438 \u2014 \u0443\u0441\u0442\u0440\u043e\u0438\u0442\u0435\u043b\u044c \u0437\u0435\u043c\u043d\u043e\u0439 \u0441\u0442\u0440\u0430\u043d\u044b, \u0434\u0435\u0440\u0436\u0430\u0449\u0438\u0439 \u043c\u0438\u0440\u043e\u043f\u043e\u0440\u044f\u0434\u043e\u043a",
    "lakshmi": "\u0418\u043d\u0430\u0440\u0438 \u2014 \u0431\u043e\u0436\u0435\u0441\u0442\u0432\u043e \u0440\u0438\u0441\u0430, \u0438\u0437\u043e\u0431\u0438\u043b\u0438\u044f \u0438 \u043f\u043b\u043e\u0434\u043e\u0440\u043e\u0434\u0438\u044f",
    "shiva": "\u0421\u0443\u0441\u0430\u043d\u043e\u043e \u2014 \u0431\u0443\u0439\u043d\u044b\u0439 \u0431\u043e\u0433 \u0431\u0443\u0440\u044c, \u0440\u0430\u0437\u0440\u0443\u0448\u0438\u0442\u0435\u043b\u044c \u0438 \u0438\u0437\u0433\u043d\u0430\u043d\u043d\u0438\u043a",
    "parvati": "\u041a\u043e\u043d\u043e\u0445\u0430\u043d\u0430-\u0441\u0430\u043a\u0443\u044f-\u0445\u0438\u043c\u044d \u2014 \u0431\u043e\u0433\u0438\u043d\u044f \u0446\u0432\u0435\u0442\u0435\u043d\u0438\u044f \u0441\u0430\u043a\u0443\u0440\u044b, \u043c\u0430\u0442\u0435\u0440\u0438\u043d\u0441\u0442\u0432\u043e \u0438 \u0437\u0430\u0431\u043e\u0442\u0430",
    "jnana": "\u041e\u043c\u043e\u0438\u043a\u0430\u043d\u044d \u2014 \u0431\u043e\u0433 \u0433\u043b\u0443\u0431\u043e\u043a\u043e\u0439 \u043c\u044b\u0441\u043b\u0438, \u043c\u0443\u0434\u0440\u043e\u0441\u0442\u0438 \u0438 \u0440\u0430\u0437\u043b\u0438\u0447\u0435\u043d\u0438\u044f",
    "prema": "\u041c\u0443\u0441\u0443\u0431\u0438 \u2014 \u0441\u0432\u044f\u0449\u0435\u043d\u043d\u0430\u044f \u0441\u0438\u043b\u0430 \u0441\u0432\u044f\u0437\u044b\u0432\u0430\u043d\u0438\u044f, \u0440\u043e\u0436\u0434\u0430\u044e\u0449\u0430\u044f \u0436\u0438\u0437\u043d\u044c \u0438 \u043b\u044e\u0431\u043e\u0432\u044c",
    "shakti": "\u0422\u0430\u043a\u044d\u043c\u0438\u043a\u0430\u0434\u0437\u0443\u0442\u0438 \u2014 \u0431\u043e\u0433 \u0433\u0440\u043e\u043c\u0430 \u0438 \u043c\u0435\u0447\u0430, \u0432\u043e\u0438\u043d\u0441\u043a\u0430\u044f \u0441\u0438\u043b\u0430",
    "ananda": "\u0410\u043c\u044d-\u043d\u043e-\u0423\u0434\u0437\u0443\u043c\u044d \u2014 \u0431\u043e\u0433\u0438\u043d\u044f \u0442\u0430\u043d\u0446\u0430 \u0438 \u0440\u0430\u0434\u043e\u0441\u0442\u0438, \u0432\u044b\u043c\u0430\u043d\u0438\u0432\u0448\u0430\u044f \u0441\u043e\u043b\u043d\u0446\u0435 \u0441\u043c\u0435\u0445\u043e\u043c",
    "shanti": "\u0422\u043e\u043a\u043e\u0451-\u043d\u043e-\u043a\u0443\u043d\u0438 \u2014 \u0437\u0430\u043c\u043e\u0440\u0441\u043a\u0430\u044f \u0441\u0442\u0440\u0430\u043d\u0430 \u0432\u0435\u0447\u043d\u043e\u0433\u043e \u043f\u043e\u043a\u043e\u044f",
    "agni": "\u041a\u0430\u0433\u0443\u0446\u0443\u0442\u0438 \u2014 \u0431\u043e\u0433 \u043e\u0433\u043d\u044f, \u0447\u044c\u0451 \u0440\u043e\u0436\u0434\u0435\u043d\u0438\u0435 \u043e\u043f\u0430\u043b\u0438\u043b\u043e \u043c\u0438\u0440",
    "vayu": "\u0421\u0438\u043d\u0430-\u0446\u0443-\u0445\u0438\u043a\u043e \u2014 \u0431\u043e\u0433 \u0432\u0435\u0442\u0440\u0430 \u0438 \u0434\u044b\u0445\u0430\u043d\u0438\u044f \u043f\u0440\u043e\u0441\u0442\u0440\u0430\u043d\u0441\u0442\u0432\u0430",
    "varuna": "\u0412\u0430\u0442\u0430\u0446\u0443\u043c\u0438 \u2014 \u0432\u043b\u0430\u0434\u044b\u043a\u0430 \u043c\u043e\u0440\u044f, \u0445\u0440\u0430\u043d\u0438\u0442\u0435\u043b\u044c \u0433\u043b\u0443\u0431\u0438\u043d \u0438 \u043f\u0430\u043c\u044f\u0442\u0438 \u0432\u043e\u0434",
    "prithvi": "\u041a\u0443\u043d\u0438-\u043d\u043e-\u0442\u043e\u043a\u043e\u0442\u0430\u0442\u0438 \u2014 \u0432\u0435\u0447\u043d\u0430\u044f \u043e\u043f\u043e\u0440\u0430 \u0437\u0435\u043c\u043b\u0438, \u0438\u0437\u043d\u0430\u0447\u0430\u043b\u044c\u043d\u0430\u044f \u0442\u0432\u0435\u0440\u0434\u044c",
    "akasha": "\u0410\u043c\u044d-\u043d\u043e-\u041c\u0438\u043d\u0430\u043a\u0430\u043d\u0443\u0441\u0438 \u2014 \u0412\u043b\u0430\u0434\u044b\u043a\u0430 \u0441\u0432\u044f\u0449\u0435\u043d\u043d\u043e\u0433\u043e \u0446\u0435\u043d\u0442\u0440\u0430 \u043d\u0435\u0431\u0435\u0441, \u043f\u0440\u043e\u0441\u0442\u043e\u0440",
    "tejas": "\u041d\u0438\u043d\u0438\u0433\u0438 \u2014 \u043d\u0435\u0431\u0435\u0441\u043d\u044b\u0439 \u0432\u043d\u0443\u043a, \u043d\u0438\u0437\u043e\u0448\u0435\u0434\u0448\u0438\u0439 \u0441\u043e \u0441\u0432\u044f\u0449\u0435\u043d\u043d\u044b\u043c \u0441\u0432\u0435\u0442\u043e\u043c",
    "dharma": "\u041a\u0430\u043d\u043d\u0430\u0433\u0430\u0440\u0430-\u043d\u043e-\u043c\u0438\u0442\u0438 \u2014 \u041f\u0443\u0442\u044c \u0431\u043e\u0433\u043e\u0432, \u0435\u0441\u0442\u0435\u0441\u0442\u0432\u0435\u043d\u043d\u044b\u0439 \u0437\u0430\u043a\u043e\u043d \u0438 \u0434\u043e\u043b\u0433",
    "karma": "\u041c\u0430\u0433\u0430\u0446\u0443\u0445\u0438 \u2014 \u0438\u0441\u043a\u0440\u0438\u0432\u043b\u044f\u044e\u0449\u0438\u0435 \u0431\u043e\u0436\u0435\u0441\u0442\u0432\u0430 \u0441\u043a\u0432\u0435\u0440\u043d\u044b, \u0446\u0435\u043f\u044c \u043f\u0440\u0438\u0447\u0438\u043d \u0438 \u0432\u043e\u0437\u0434\u0430\u044f\u043d\u0438\u044f"
  },
  "resonance_keywords": ["\u043a\u0430\u043c\u0438", "\u0425\u0430\u0440\u0430\u044d", "\u041a\u0435\u0433\u0430\u0440\u0435", "\u0410\u043c\u0430\u0442\u044d\u0440\u0430\u0441\u0443", "\u0441\u0438\u043d\u0442\u0430\u0439", "\u043c\u0438\u0441\u043e\u0433\u0438", "\u0442\u043e\u0440\u0438\u0438", "\u043c\u0443\u0441\u0443\u0431\u0438", "\u043c\u0430\u043a\u043e\u0442\u043e", "\u043c\u0430\u0446\u0443\u0440\u0438"],
  "visual_code": "\u0442\u043e\u0440\u0438\u0438 \u0443 \u0432\u043e\u0434\u044b, \u0431\u0435\u043b\u044b\u0435 \u0441\u0438\u0434\u044d \u0438 \u0433\u043e\u0445\u044d\u0439, \u0437\u0435\u0440\u043a\u0430\u043b\u043e \u042f\u0442\u0430, \u0437\u043e\u043b\u043e\u0442\u043e\u0439 \u0448\u043e\u0432 \u043a\u0438\u043d\u0446\u0443\u0433\u0438 \u043d\u0430 \u0447\u0430\u0448\u0435, \u0441\u0430\u043a\u0443\u0440\u0430 \u0438 \u0432\u043e\u0441\u0445\u043e\u0434 \u043d\u0430\u0434 \u043c\u043e\u0440\u0435\u043c, \u0441\u0432\u044f\u0449\u0435\u043d\u043d\u044b\u0435 \u0433\u043e\u0440\u044b-\u0441\u0438\u043d\u0442\u0430\u0439, \u043e\u0447\u0438\u0449\u0430\u044e\u0449\u0430\u044f \u0432\u043e\u0434\u0430 \u043c\u0438\u0441\u043e\u0433\u0438",
