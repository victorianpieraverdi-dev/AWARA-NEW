  "guna_accent": "\u0441\u0430\u0442\u0442\u0432\u0430",
  "graha_accent": "\u0421\u043e\u043b\u043d\u0446\u0435",
  "pole": {
    "toward": "\u0411\u043e\u0434\u0445\u0438 \u2014 \u043f\u0440\u043e\u0431\u0443\u0436\u0434\u0451\u043d\u043d\u043e\u0435 \u0441\u043e\u0437\u043d\u0430\u043d\u0438\u0435, \u044f\u0441\u043d\u044b\u0439 \u0441\u0432\u0435\u0442 \u041a\u0430\u043b\u0430\u0447\u0430\u043a\u0440\u044b \u0438 \u0433\u0430\u0440\u043c\u043e\u043d\u0438\u044f \u041a\u043e\u043b\u0435\u0441\u0430 \u0412\u0440\u0435\u043c\u0435\u043d\u0438",
    "away": "\u042d\u043f\u043e\u0445\u0430 \u0443\u043f\u0430\u0434\u043a\u0430 \u2014 \u043e\u043c\u0440\u0430\u0447\u0435\u043d\u0438\u0435 \u0414\u0445\u0430\u0440\u043c\u044b, \u0440\u0430\u0437\u0434\u0440\u043e\u0431\u043b\u0435\u043d\u043d\u043e\u0441\u0442\u044c \u0432\u0440\u0435\u043c\u0435\u043d\u0438 \u0438 \u0432\u043b\u0430\u0441\u0442\u044c \u043d\u0435\u0432\u0435\u0436\u0435\u0441\u0442\u0432\u0430",
    "note": "\u0421\u0432\u0435\u0442 \u2014 \u0432\u0440\u0430\u0449\u0430\u0442\u044c \u041a\u043e\u043b\u0435\u0441\u043e \u0412\u0440\u0435\u043c\u0435\u043d\u0438 \u0432 \u0441\u043e\u0433\u043b\u0430\u0441\u0438\u0438, \u043e\u0447\u0438\u0449\u0430\u044f \u0432\u0435\u0442\u0440\u044b \u0438 \u043a\u0430\u043f\u043b\u0438 \u043a \u0411\u043e\u0434\u0445\u0438; \u0442\u0435\u043d\u044c \u2014 \u043f\u043e\u0433\u0440\u0443\u0437\u0438\u0442\u044c\u0441\u044f \u0432 \u044d\u043f\u043e\u0445\u0443 \u0443\u043f\u0430\u0434\u043a\u0430, \u0433\u0434\u0435 \u0432\u0440\u0435\u043c\u044f \u0434\u0440\u043e\u0431\u0438\u0442 \u0438 \u043f\u043e\u0440\u0430\u0431\u043e\u0449\u0430\u0435\u0442"
  },
  "core": "\u041b\u0438\u043d\u0437\u0430 \u0411\u043e\u0434\u0445\u0438 \u0438 \u044d\u043f\u043e\u0445\u0438 \u0443\u043f\u0430\u0434\u043a\u0430: \u0432\u043d\u0435\u0448\u043d\u0435\u0435, \u0432\u043d\u0443\u0442\u0440\u0435\u043d\u043d\u0435\u0435 \u0438 \u0438\u043d\u043e\u0435 \u041a\u043e\u043b\u0435\u0441\u043e \u0412\u0440\u0435\u043c\u0435\u043d\u0438 \u0435\u0434\u0438\u043d\u044b; \u0432\u043e\u0441\u0445\u043e\u0436\u0434\u0435\u043d\u0438\u0435 \u2014 \u0441\u0438\u043d\u0445\u0440\u043e\u043d\u0438\u0437\u0438\u0440\u043e\u0432\u0430\u0442\u044c \u0442\u0435\u043b\u043e-\u043a\u043e\u0441\u043c\u043e\u0441 \u0441 \u041a\u0430\u043b\u0430\u0447\u0430\u043a\u0440\u043e\u0439, \u043e\u0447\u0438\u0441\u0442\u0438\u0442\u044c \u0432\u0435\u0442\u0440\u044b \u0438 \u043a\u0430\u043f\u043b\u0438 \u0438 \u043f\u0440\u043e\u0431\u0443\u0434\u0438\u0442\u044c \u044f\u0441\u043d\u044b\u0439 \u0441\u0432\u0435\u0442, \u0432\u0435\u0434\u044f \u043c\u0438\u0440 \u0438\u0437 \u0442\u0451\u043c\u043d\u043e\u0439 \u044d\u043f\u043e\u0445\u0438 \u0432 \u0437\u043e\u043b\u043e\u0442\u043e\u0439 \u0432\u0435\u043a \u0428\u0430\u043c\u0431\u0430\u043b\u044b.",
  "faces": {
    "svet_ra": "\u0410\u0434\u0438-\u0411\u0443\u0434\u0434\u0430 \u2014 \u0438\u0437\u043d\u0430\u0447\u0430\u043b\u044c\u043d\u044b\u0439 \u0411\u0443\u0434\u0434\u0430, \u0438\u0441\u0442\u043e\u043a \u044f\u0441\u043d\u043e\u0433\u043e \u0441\u0432\u0435\u0442\u0430 \u0438 \u0441\u043e\u0437\u043d\u0430\u043d\u0438\u044f",
    "iskra": "\u0412\u0438\u0448\u0432\u0430\u043c\u0430\u0442\u0430 \u2014 \u043c\u0430\u0442\u044c-\u043c\u0443\u0434\u0440\u043e\u0441\u0442\u044c, \u043b\u0443\u043d\u043d\u0430\u044f \u0441\u0443\u043f\u0440\u0443\u0433\u0430 \u041a\u0430\u043b\u0430\u0447\u0430\u043a\u0440\u044b, \u0442\u0438\u0445\u0438\u0439 \u0437\u043e\u0432 \u043f\u0443\u0441\u0442\u043e\u0442\u044b",
    "brahma": "\u041a\u0430\u043b\u0430\u0447\u0430\u043a\u0440\u0430 \u2014 \u041a\u043e\u043b\u0435\u0441\u043e \u0412\u0440\u0435\u043c\u0435\u043d\u0438, \u0431\u043e\u0436\u0435\u0441\u0442\u0432\u043e, \u0440\u0430\u0437\u0432\u043e\u0440\u0430\u0447\u0438\u0432\u0430\u044e\u0449\u0435\u0435 \u0444\u043e\u0440\u043c\u0443 \u0432\u0440\u0435\u043c\u0435\u043d\u0438 \u0438 \u043a\u043e\u0441\u043c\u043e\u0441\u0430",
    "sarasvati": "\u041c\u0430\u043d\u0434\u0436\u0443\u0448\u0440\u0438 \u2014 \u0431\u043e\u0434\u0445\u0438\u0441\u0430\u0442\u0442\u0432\u0430 \u043c\u0443\u0434\u0440\u043e\u0441\u0442\u0438 \u0438 \u0441\u0432\u044f\u0449\u0435\u043d\u043d\u043e\u0433\u043e \u0441\u043b\u043e\u0432\u0430 \u0442\u0430\u043d\u0442\u0440\u044b",
    "vishnu": "\u0421\u0443\u0447\u0430\u043d\u0434\u0440\u0430 \u2014 \u043f\u0435\u0440\u0432\u044b\u0439 \u0446\u0430\u0440\u044c \u0428\u0430\u043c\u0431\u0430\u043b\u044b, \u043f\u0440\u0438\u043d\u044f\u0432\u0448\u0438\u0439 \u0443\u0447\u0435\u043d\u0438\u0435 \u0438 \u0445\u0440\u0430\u043d\u044f\u0449\u0438\u0439 \u0414\u0445\u0430\u0440\u043c\u0443",
    "lakshmi": "\u0426\u0430\u0440\u0441\u0442\u0432\u043e \u0428\u0430\u043c\u0431\u0430\u043b\u044b \u2014 \u0441\u043e\u043a\u0440\u043e\u0432\u0435\u043d\u043d\u0430\u044f \u0437\u0435\u043c\u043b\u044f \u0438\u0437\u043e\u0431\u0438\u043b\u0438\u044f \u0438 \u043f\u0440\u043e\u0446\u0432\u0435\u0442\u0430\u043d\u0438\u044f \u0414\u0445\u0430\u0440\u043c\u044b",
    "shiva": "\u0420\u0443\u0434\u0440\u0430 \u0427\u0430\u043a\u0440\u0438\u043d \u2014 25-\u0439 \u0446\u0430\u0440\u044c-\u041a\u0430\u043b\u043a\u0438, \u0441\u043e\u043a\u0440\u0443\u0448\u0430\u044e\u0449\u0438\u0439 \u0441\u0438\u043b\u044b \u0442\u044c\u043c\u044b \u0432 \u0444\u0438\u043d\u0430\u043b\u044c\u043d\u043e\u0439 \u0431\u0438\u0442\u0432\u0435",
    "parvati": "\u0422\u0430\u0440\u0430 \u2014 \u0431\u043e\u0434\u0445\u0438\u0441\u0430\u0442\u0442\u0432\u0430-\u043c\u0430\u0442\u044c \u0441\u043e\u0441\u0442\u0440\u0430\u0434\u0430\u043d\u0438\u044f \u0438 \u0437\u0430\u0449\u0438\u0442\u044b, \u0437\u0430\u0431\u043e\u0442\u0430",
    "jnana": "\u041f\u0440\u0430\u0434\u0436\u043d\u044f\u043f\u0430\u0440\u0430\u043c\u0438\u0442\u0430 \u2014 \u0441\u043e\u0432\u0435\u0440\u0448\u0435\u043d\u043d\u0430\u044f \u043c\u0443\u0434\u0440\u043e\u0441\u0442\u044c, \u0440\u0430\u0437\u043b\u0438\u0447\u0435\u043d\u0438\u0435 \u043f\u0443\u0441\u0442\u043e\u0442\u044b",
    "prema": "\u0410\u0432\u0430\u043b\u043e\u043a\u0438\u0442\u0435\u0448\u0432\u0430\u0440\u0430 \u2014 \u0431\u043e\u0434\u0445\u0438\u0441\u0430\u0442\u0442\u0432\u0430 \u0431\u0435\u0437\u0433\u0440\u0430\u043d\u0438\u0447\u043d\u043e\u0433\u043e \u0441\u043e\u0441\u0442\u0440\u0430\u0434\u0430\u043d\u0438\u044f \u0438 \u043b\u044e\u0431\u0432\u0438",
    "shakti": "\u0412\u0430\u0434\u0436\u0440\u0430\u043f\u0430\u043d\u0438 \u2014 \u0433\u043d\u0435\u0432\u043d\u044b\u0439 \u0434\u0435\u0440\u0436\u0430\u0442\u0435\u043b\u044c \u0432\u0430\u0434\u0436\u0440\u044b, \u0437\u0430\u0449\u0438\u0442\u043d\u0430\u044f \u0441\u0438\u043b\u0430 \u0414\u0445\u0430\u0440\u043c\u044b",
    "ananda": "\u041c\u0430\u0445\u0430\u0441\u0443\u043a\u0445\u0430 \u2014 \u0432\u0435\u043b\u0438\u043a\u043e\u0435 \u0431\u043b\u0430\u0436\u0435\u043d\u0441\u0442\u0432\u043e \u0435\u0434\u0438\u043d\u0441\u0442\u0432\u0430 \u0431\u043b\u0430\u0436\u0435\u043d\u0441\u0442\u0432\u0430 \u0438 \u043f\u0443\u0441\u0442\u043e\u0442\u044b",
    "shanti": "\u041a\u0430\u043b\u0430\u043f\u0430 \u2014 \u0445\u0440\u0443\u0441\u0442\u0430\u043b\u044c\u043d\u0430\u044f \u0441\u0442\u043e\u043b\u0438\u0446\u0430 \u0428\u0430\u043c\u0431\u0430\u043b\u044b, \u043e\u0431\u0438\u0442\u0435\u043b\u044c \u043f\u043e\u043a\u043e\u044f \u0438 \u0414\u0445\u0430\u0440\u043c\u044b",
    "agni": "\u0422\u0443\u043c\u043c\u043e \u2014 \u0432\u043d\u0443\u0442\u0440\u0435\u043d\u043d\u0438\u0439 \u043e\u0433\u043e\u043d\u044c \u0439\u043e\u0433\u0438, \u043f\u0440\u0435\u043e\u0431\u0440\u0430\u0437\u0443\u044e\u0449\u0435\u0435 \u043f\u043b\u0430\u043c\u044f \u0447\u0430\u043d\u0434\u0430\u043b\u0438",
    "vayu": "\u041f\u0440\u0430\u043d\u0430-\u0432\u0430\u044e \u2014 \u0436\u0438\u0437\u043d\u0435\u043d\u043d\u044b\u0435 \u0432\u0435\u0442\u0440\u044b, \u0434\u044b\u0445\u0430\u043d\u0438\u0435 \u0432 \u0442\u043e\u043d\u043a\u0438\u0445 \u043a\u0430\u043d\u0430\u043b\u0430\u0445 \u0442\u0435\u043b\u0430",
    "varuna": "\u041d\u0430\u0433\u0438 \u2014 \u0432\u043e\u0434\u043d\u044b\u0435 \u0437\u043c\u0438\u0438, \u0441\u0442\u0440\u0430\u0436\u0438 \u0433\u043b\u0443\u0431\u0438\u043d \u0438 \u0441\u043e\u043a\u0440\u044b\u0442\u043e\u0439 \u043f\u0430\u043c\u044f\u0442\u0438 \u0443\u0447\u0435\u043d\u0438\u0439",
    "prithvi": "\u0421\u0443\u043c\u0435\u0440\u0443 \u2014 \u043a\u043e\u0441\u043c\u0438\u0447\u0435\u0441\u043a\u0430\u044f \u0433\u043e\u0440\u0430-\u043e\u0441\u044c, \u043e\u043f\u043e\u0440\u0430 \u043c\u0438\u0440\u0430",
    "akasha": "\u0414\u0445\u0430\u0440\u043c\u0430\u0434\u0445\u0430\u0442\u0443 \u2014 \u043f\u0440\u043e\u0441\u0442\u0440\u0430\u043d\u0441\u0442\u0432\u043e \u0432\u0441\u0435\u0445 \u0434\u0445\u0430\u0440\u043c, \u0430\u0431\u0441\u043e\u043b\u044e\u0442\u043d\u044b\u0439 \u043f\u0440\u043e\u0441\u0442\u043e\u0440 \u0443\u043c\u0430",
    "tejas": "\u0412\u0430\u0439\u0440\u043e\u0447\u0430\u043d\u0430 \u2014 \u0411\u0443\u0434\u0434\u0430 \u0441\u0438\u044f\u044e\u0449\u0435\u0433\u043e \u0441\u0432\u0435\u0442\u0430, \u043b\u0443\u0447\u0435\u0437\u0430\u0440\u043d\u043e\u0435 \u043e\u0437\u0430\u0440\u0435\u043d\u0438\u0435",
    "dharma": "\u0414\u0445\u0430\u0440\u043c\u0430\u0440\u0430\u0434\u0436\u0438 \u2014 \u0446\u0430\u0440\u0438-\u0445\u0440\u0430\u043d\u0438\u0442\u0435\u043b\u0438 \u0437\u0430\u043a\u043e\u043d\u0430 \u0414\u0445\u0430\u0440\u043c\u044b \u0438 \u043e\u0431\u0435\u0442\u0430 \u0431\u043e\u0434\u0445\u0438\u0441\u0430\u0442\u0442\u0432\u044b",
    "karma": "\u041f\u0440\u0430\u0442\u0438\u0442\u044c\u044f\u0441\u0430\u043c\u0443\u0442\u043f\u0430\u0434\u0430 \u2014 \u0432\u0437\u0430\u0438\u043c\u043e\u0437\u0430\u0432\u0438\u0441\u0438\u043c\u043e\u0435 \u0432\u043e\u0437\u043d\u0438\u043a\u043d\u043e\u0432\u0435\u043d\u0438\u0435, \u0446\u0435\u043f\u044c \u043f\u0440\u0438\u0447\u0438\u043d \u0438 \u0441\u043b\u0435\u0434\u0441\u0442\u0432\u0438\u0439"
  },
  "resonance_keywords": ["\u041a\u0430\u043b\u0430\u0447\u0430\u043a\u0440\u0430", "\u0428\u0430\u043c\u0431\u0430\u043b\u0430", "\u0411\u043e\u0434\u0445\u0438", "\u0410\u0434\u0438-\u0411\u0443\u0434\u0434\u0430", "\u0420\u0438\u0433\u0434\u0435\u043d\u044b", "\u041a\u0430\u043b\u0430\u043f\u0430", "\u044f\u0441\u043d\u044b\u0439 \u0441\u0432\u0435\u0442", "\u0432\u0435\u0442\u0440\u044b \u0438 \u043a\u0430\u043f\u043b\u0438", "\u041a\u043e\u043b\u0435\u0441\u043e \u0412\u0440\u0435\u043c\u0435\u043d\u0438", "\u0437\u043e\u043b\u043e\u0442\u043e\u0439 \u0432\u0435\u043a"],
  "visual_code": "\u043c\u0430\u043d\u0434\u0430\u043b\u0430 \u041a\u0430\u043b\u0430\u0447\u0430\u043a\u0440\u044b, \u0434\u0435\u0441\u044f\u0442\u0438\u0441\u043b\u043e\u0433\u043e\u0432\u0430\u044f \u043c\u043e\u043d\u043e\u0433\u0440\u0430\u043c\u043c\u0430 \u041d\u0430\u043c\u0447\u0443\u0432\u0430\u043d\u0433\u0434\u0435\u043d, \u0445\u0440\u0443\u0441\u0442\u0430\u043b\u044c\u043d\u0430\u044f \u0441\u0442\u043e\u043b\u0438\u0446\u0430 \u041a\u0430\u043b\u0430\u043f\u0430 \u0432 \u043a\u043e\u043b\u044c\u0446\u0435 \u0441\u043d\u0435\u0436\u043d\u044b\u0445 \u0433\u043e\u0440, \u0446\u0430\u0440\u0438-\u0420\u0438\u0433\u0434\u0435\u043d\u044b \u043d\u0430 \u0442\u0440\u043e\u043d\u0430\u0445, \u0441\u043e\u043b\u043d\u0435\u0447\u043d\u044b\u0439 \u0438 \u043b\u0443\u043d\u043d\u044b\u0439 \u0434\u0438\u0441\u043a\u0438, \u0432\u0430\u0434\u0436\u0440\u0430 \u0438 \u043a\u043e\u043b\u043e\u043a\u043e\u043b, \u0437\u043e\u043b\u043e\u0442\u043e\u0435 \u043a\u043e\u043b\u0435\u0441\u043e \u0432\u0440\u0435\u043c\u0435\u043d\u0438",
