{
  "matrix_slug": "norse",
  "matrix_name": "\u0421\u043a\u0430\u043d\u0434\u0438\u043d\u0430\u0432\u0441\u043a\u0430\u044f",
  "element_accent": "\u0417\u0435\u043c\u043b\u044f",
  "chakra_accent": "\u0410\u0434\u0436\u043d\u0430",
  "guna_accent": "\u0440\u0430\u0434\u0436\u0430\u0441",
  "graha_accent": "\u0421\u0430\u0442\u0443\u0440\u043d",
  "pole": {
    "toward": "\u0412\u0438\u0440\u0434 \u2014 \u043f\u0440\u0438\u043d\u044f\u0442\u044c \u0441\u0432\u043e\u044e \u0441\u0443\u0434\u044c\u0431\u0443-\u043f\u043b\u0435\u0442\u0435\u043d\u0438\u0435 \u0438 \u0432\u0441\u0442\u0440\u0435\u0442\u0438\u0442\u044c \u0435\u0451 \u0441 \u0434\u043e\u0431\u043b\u0435\u0441\u0442\u044c\u044e, \u0438\u0441\u043f\u043e\u043b\u043d\u0438\u0432 \u0434\u043e\u043b\u0433 \u043f\u0435\u0440\u0435\u0434 \u0440\u043e\u0434\u043e\u043c \u0438 \u0431\u043e\u0433\u0430\u043c\u0438",
    "away": "\u0420\u0430\u0437\u0440\u044b\u0432 \u043d\u0438\u0442\u0435\u0439 \u2014 \u0431\u0435\u0433\u0441\u0442\u0432\u043e \u043e\u0442 \u0441\u0443\u0434\u044c\u0431\u044b, \u0431\u0435\u0441\u0447\u0435\u0441\u0442\u044c\u0435 \u0438 \u0442\u0440\u0443\u0441\u043e\u0441\u0442\u044c, \u0447\u0442\u043e \u043f\u0440\u0438\u0431\u043b\u0438\u0436\u0430\u0435\u0442 \u0420\u0430\u0433\u043d\u0430\u0440\u0451\u043a",
    "note": "\u0421\u0432\u0435\u0442 \u2014 \u0434\u043e\u0431\u043b\u0435\u0441\u0442\u043d\u043e \u043f\u0440\u0438\u043d\u044f\u0442\u044c \u0432\u0438\u0440\u0434 \u043d\u043e\u0440\u043d \u0438 \u0438\u0434\u0442\u0438 \u043a \u0420\u0430\u0433\u043d\u0430\u0440\u0451\u043a\u0443 \u0441 \u0447\u0435\u0441\u0442\u044c\u044e; \u0442\u0435\u043d\u044c \u2014 \u043f\u0440\u0435\u0434\u0430\u0442\u044c \u043a\u043b\u044f\u0442\u0432\u044b, \u0432\u043f\u0430\u0441\u0442\u044c \u0432 \u0431\u0435\u0441\u0447\u0435\u0441\u0442\u044c\u0435 \u0438 \u0441\u0442\u0440\u0430\u0445"
  },
  "core": "\u041b\u0438\u043d\u0437\u0430 \u0412\u0438\u0440\u0434\u0430: \u043c\u0438\u0440 \u2014 \u0441\u043f\u043b\u0435\u0442\u0435\u043d\u0438\u0435 \u043d\u0438\u0442\u0435\u0439 \u0441\u0443\u0434\u044c\u0431\u044b \u0443 \u043a\u043e\u0440\u043d\u0435\u0439 \u0418\u0433\u0433\u0434\u0440\u0430\u0441\u0438\u043b\u044f, \u043f\u0443\u0442\u044c \u043a \u0420\u0430\u0433\u043d\u0430\u0440\u0451\u043a\u0443 \u0438 \u043e\u0431\u043d\u043e\u0432\u043b\u0435\u043d\u0438\u044e; \u0432\u043e\u0441\u0445\u043e\u0436\u0434\u0435\u043d\u0438\u0435 \u2014 \u043f\u0440\u0438\u043d\u044f\u0442\u044c \u0441\u0432\u043e\u0439 \u0443\u0434\u0435\u043b \u0438 \u0432\u0441\u0442\u0440\u0435\u0442\u0438\u0442\u044c \u0435\u0433\u043e \u0441 \u0434\u043e\u0431\u043b\u0435\u0441\u0442\u044c\u044e \u0438 \u0447\u0435\u0441\u0442\u044c\u044e.",
  "faces": {
    "svet_ra": "\u041e\u0434\u0438\u043d \u2014 \u0412\u0441\u0435\u043e\u0442\u0435\u0446, \u0434\u0443\u0445 \u0436\u0438\u0437\u043d\u0438 \u0438 \u0438\u0441\u0442\u043e\u043a, \u0447\u0442\u043e \u0441\u043e\u0437\u0434\u0430\u043b \u043c\u0438\u0440\u044b \u0438\u0437 \u0442\u0435\u043b\u0430 \u0418\u043c\u0438\u0440\u0430",
    "iskra": "\u041c\u0430\u043d\u0438 \u2014 \u043b\u0443\u043d\u0430, \u043d\u043e\u0447\u043d\u043e\u0435 \u0441\u0432\u0435\u0442\u0438\u043b\u043e \u0438 \u0437\u043e\u0432 \u0432 \u0442\u0435\u043c\u043d\u043e\u0442\u0435",
    "brahma": "\u0412\u0438\u043b\u0438 \u0438 \u0412\u0435 \u2014 \u0431\u0440\u0430\u0442\u044c\u044f-\u0442\u0432\u043e\u0440\u0446\u044b, \u0434\u0430\u0432\u0448\u0438\u0435 \u043c\u0438\u0440\u0443 \u043e\u0431\u043b\u0438\u043a \u0438 \u0444\u043e\u0440\u043c\u0443",
    "sarasvati": "\u0411\u0440\u0430\u0433\u0438 \u2014 \u0431\u043e\u0433 \u043f\u043e\u044d\u0437\u0438\u0438, \u043a\u0440\u0430\u0441\u043d\u043e\u0440\u0435\u0447\u0438\u044f \u0438 \u0441\u043b\u043e\u0432\u0430",
    "vishnu": "\u0424\u0440\u0435\u0439\u0440 \u2014 \u0431\u043e\u0433 \u043f\u043b\u043e\u0434\u043e\u0440\u043e\u0434\u0438\u044f, \u043c\u0438\u0440\u0430 \u0438 \u043f\u0440\u043e\u0446\u0432\u0435\u0442\u0430\u043d\u0438\u044f",
    "lakshmi": "\u041d\u044c\u0451\u0440\u0434 \u2014 \u0431\u043e\u0433 \u043c\u043e\u0440\u044f, \u0431\u043e\u0433\u0430\u0442\u0441\u0442\u0432\u0430 \u0438 \u0438\u0437\u043e\u0431\u0438\u043b\u0438\u044f",
    "shiva": "\u0421\u0443\u0440\u0442 \u2014 \u043e\u0433\u043d\u0435\u043d\u043d\u044b\u0439 \u0432\u0435\u043b\u0438\u043a\u0430\u043d \u041c\u0443\u0441\u043f\u0435\u043b\u044c\u0445\u0435\u0439\u043c\u0430, \u0440\u0430\u0437\u0440\u0443\u0448\u0438\u0442\u0435\u043b\u044c \u0432 \u0420\u0430\u0433\u043d\u0430\u0440\u0451\u043a",
    "parvati": "\u0424\u0440\u0438\u0433\u0433 \u2014 \u043c\u0430\u0442\u044c \u0431\u043e\u0433\u043e\u0432, \u043f\u043e\u043a\u0440\u043e\u0432\u0438\u0442\u0435\u043b\u044c\u043d\u0438\u0446\u0430 \u0431\u0440\u0430\u043a\u0430 \u0438 \u0445\u0440\u0430\u043d\u0438\u0442\u0435\u043b\u044c\u043d\u0438\u0446\u0430 \u0437\u043d\u0430\u043d\u0438\u044f \u0441\u0443\u0434\u044c\u0431\u044b",
    "jnana": "\u041c\u0438\u043c\u0438\u0440 \u2014 \u0441\u0442\u0440\u0430\u0436 \u0438\u0441\u0442\u043e\u0447\u043d\u0438\u043a\u0430 \u043c\u0443\u0434\u0440\u043e\u0441\u0442\u0438, \u043f\u0430\u043c\u044f\u0442\u044c \u0438 \u0440\u0430\u0437\u043b\u0438\u0447\u0435\u043d\u0438\u0435",
    "prema": "\u0424\u0440\u0435\u0439\u044f \u2014 \u0431\u043e\u0433\u0438\u043d\u044f \u043b\u044e\u0431\u0432\u0438, \u043a\u0440\u0430\u0441\u043e\u0442\u044b \u0438 \u0441\u0442\u0440\u0430\u0441\u0442\u0438",
    "shakti": "\u0422\u043e\u0440 \u2014 \u0433\u0440\u043e\u043c\u043e\u0432\u0435\u0440\u0436\u0435\u0446, \u0441\u0438\u043b\u0430, \u0437\u0430\u0449\u0438\u0442\u0430 \u0438 \u0432\u043e\u0438\u043d\u0441\u043a\u0430\u044f \u043c\u043e\u0449\u044c",
    "ananda": "\u0411\u0430\u043b\u044c\u0434\u0440 \u2014 \u0441\u0438\u044f\u044e\u0449\u0438\u0439 \u0431\u043e\u0433 \u0441\u0432\u0435\u0442\u0430, \u0440\u0430\u0434\u043e\u0441\u0442\u0438 \u0438 \u0431\u043b\u0430\u0436\u0435\u043d\u0441\u0442\u0432\u0430",
    "shanti": "\u0413\u0438\u043c\u043b\u0435 \u2014 \u0437\u043e\u043b\u043e\u0442\u043e\u0439 \u0447\u0435\u0440\u0442\u043e\u0433 \u043f\u043e\u0441\u043b\u0435 \u0420\u0430\u0433\u043d\u0430\u0440\u0451\u043a\u0430, \u043f\u043e\u043a\u043e\u0439 \u0438 \u043e\u0431\u043d\u043e\u0432\u043b\u0451\u043d\u043d\u044b\u0439 \u043c\u0438\u0440",
    "agni": "\u041b\u043e\u0433\u0438 \u2014 \u0434\u0438\u043a\u043e\u0435 \u043f\u043b\u0430\u043c\u044f, \u0436\u0435\u0440\u0442\u0432\u0435\u043d\u043d\u044b\u0439 \u043e\u0433\u043e\u043d\u044c \u0431\u043b\u043e\u0442\u0430",
    "vayu": "\u041a\u0430\u0440\u0438 \u2014 \u043e\u043b\u0438\u0446\u0435\u0442\u0432\u043e\u0440\u0435\u043d\u0438\u0435 \u0432\u0435\u0442\u0440\u0430, \u0434\u044b\u0445\u0430\u043d\u0438\u0435 \u0438 \u0434\u0432\u0438\u0436\u0435\u043d\u0438\u0435 \u0432\u043e\u0437\u0434\u0443\u0445\u0430",
    "varuna": "\u042d\u0433\u0438\u0440 \u2014 \u0432\u043b\u0430\u0434\u044b\u043a\u0430 \u043c\u043e\u0440\u0441\u043a\u0438\u0445 \u0432\u043e\u0434, \u0433\u043b\u0443\u0431\u0438\u043d\u0430 \u0438 \u043f\u0430\u043c\u044f\u0442\u044c \u0431\u0435\u0437\u0434\u043d\u044b",
    "prithvi": "\u0401\u0440\u0434 \u2014 \u043c\u0430\u0442\u044c-\u0437\u0435\u043c\u043b\u044f, \u0442\u0432\u0435\u0440\u0434\u044c \u0438 \u043e\u043f\u043e\u0440\u0430 \u043c\u0438\u0440\u043e\u0432",
    "akasha": "\u0418\u0433\u0433\u0434\u0440\u0430\u0441\u0438\u043b\u044c \u2014 \u043c\u0438\u0440\u043e\u0432\u043e\u0435 \u0434\u0440\u0435\u0432\u043e, \u043e\u0441\u044c \u0438 \u043f\u0440\u043e\u0441\u0442\u0440\u0430\u043d\u0441\u0442\u0432\u043e \u0434\u0435\u0432\u044f\u0442\u0438 \u043c\u0438\u0440\u043e\u0432",
    "tejas": "\u0421\u043e\u043b\u044c \u2014 \u0441\u043e\u043b\u043d\u0435\u0447\u043d\u0430\u044f \u0434\u0435\u0432\u0430, \u0441\u0438\u044f\u043d\u0438\u0435 \u0441\u0432\u0435\u0442\u0438\u043b\u0430",
    "dharma": "\u0422\u044e\u0440 \u2014 \u0431\u043e\u0433 \u0437\u0430\u043a\u043e\u043d\u0430, \u0441\u043f\u0440\u0430\u0432\u0435\u0434\u043b\u0438\u0432\u043e\u0441\u0442\u0438, \u043a\u043b\u044f\u0442\u0432 \u0438 \u0434\u043e\u043b\u0433\u0430",
    "karma": "\u041d\u043e\u0440\u043d\u044b \u2014 \u0423\u0440\u0434, \u0412\u0435\u0440\u0434\u0430\u043d\u0434\u0438 \u0438 \u0421\u043a\u0443\u043b\u044c\u0434, \u043f\u0440\u044f\u0445\u0438 \u0441\u0443\u0434\u044c\u0431\u044b \u0443 \u0418\u0433\u0433\u0434\u0440\u0430\u0441\u0438\u043b\u044f"
  },
  "resonance_keywords": ["\u0412\u0438\u0440\u0434", "\u041d\u043e\u0440\u043d\u044b", "\u0418\u0433\u0433\u0434\u0440\u0430\u0441\u0438\u043b\u044c", "\u0420\u0430\u0433\u043d\u0430\u0440\u0451\u043a", "\u0440\u0443\u043d\u044b", "\u0410\u0441\u0433\u0430\u0440\u0434", "\u0434\u043e\u0431\u043b\u0435\u0441\u0442\u044c", "\u0412\u0430\u043b\u044c\u0445\u0430\u043b\u043b\u0430", "\u0434\u0435\u0432\u044f\u0442\u044c \u043c\u0438\u0440\u043e\u0432", "\u0441\u0443\u0434\u044c\u0431\u0430"],
  "visual_code": "\u044f\u0441\u0435\u043d\u044c \u0418\u0433\u0433\u0434\u0440\u0430\u0441\u0438\u043b\u044c, \u0440\u0443\u043d\u0438\u0447\u0435\u0441\u043a\u0438\u0435 \u043a\u0430\u043c\u043d\u0438, \u0432\u043e\u0440\u043e\u043d\u044b \u0425\u0443\u0433\u0438\u043d \u0438 \u041c\u0443\u043d\u0438\u043d, \u043c\u043e\u043b\u043e\u0442 \u041c\u044c\u0451\u043b\u044c\u043d\u0438\u0440, \u043b\u0430\u0434\u044c\u0438-\u0434\u0440\u0430\u043a\u043a\u0430\u0440\u044b, \u0441\u0435\u0432\u0435\u0440\u043d\u043e\u0435 \u0441\u0438\u044f\u043d\u0438\u0435, \u0432\u0430\u043b\u044c\u043a\u043d\u0443\u0442 \u0438 \u043f\u0435\u0440\u0435\u043f\u043b\u0435\u0442\u0451\u043d\u043d\u044b\u0435 \u0443\u0437\u043b\u044b",
  "sources": ["https://en.wikipedia.org/wiki/Norse_mythology", "https://en.wikipedia.org/wiki/Norns", "https://en.wikipedia.org/wiki/Yggdrasil", "https://en.wikipedia.org/wiki/Wyrd", "https://en.wikipedia.org/wiki/Ragnar\u00f6k", "https://en.wikipedia.org/wiki/Odin"]
}
