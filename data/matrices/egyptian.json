{
  "matrix_slug": "egyptian",
  "matrix_name": "\u0415\u0433\u0438\u043f\u0435\u0442\u0441\u043a\u0430\u044f",
  "element_accent": "\u041e\u0433\u043e\u043d\u044c",
  "chakra_accent": "\u0410\u043d\u0430\u0445\u0430\u0442\u0430",
  "guna_accent": "\u0441\u0430\u0442\u0442\u0432\u0430",
  "graha_accent": "\u0421\u043e\u043b\u043d\u0446\u0435",
  "pole": {
    "toward": "\u041c\u0430\u0430\u0442 \u2014 \u0438\u0441\u0442\u0438\u043d\u0430, \u043f\u043e\u0440\u044f\u0434\u043e\u043a \u0438 \u0440\u0430\u0432\u043d\u043e\u0432\u0435\u0441\u0438\u0435 \u043a\u043e\u0441\u043c\u043e\u0441\u0430; \u0436\u0438\u0437\u043d\u044c \u0432 \u0441\u043e\u0433\u043b\u0430\u0441\u0438\u0438 \u0441 \u0437\u0430\u043a\u043e\u043d\u043e\u043c \u0438 \u0441\u043f\u0440\u0430\u0432\u0435\u0434\u043b\u0438\u0432\u043e\u0441\u0442\u044c\u044e",
    "away": "\u0418\u0441\u0444\u0435\u0442 \u2014 \u0445\u0430\u043e\u0441, \u043b\u043e\u0436\u044c \u0438 \u0440\u0430\u0441\u043f\u0430\u0434; \u043d\u0430\u0440\u0443\u0448\u0435\u043d\u0438\u0435 \u043f\u043e\u0440\u044f\u0434\u043a\u0430, \u0432\u0435\u0434\u0443\u0449\u0435\u0435 \u043a \u0442\u044c\u043c\u0435 \u0438 \u0440\u0430\u0437\u043b\u043e\u0436\u0435\u043d\u0438\u044e",
    "note": "\u0421\u0432\u0435\u0442 \u2014 \u0434\u0435\u0440\u0436\u0430\u0442\u044c \u041c\u0430\u0430\u0442: \u0436\u0438\u0442\u044c \u043f\u043e \u0438\u0441\u0442\u0438\u043d\u0435, \u043c\u0435\u0440\u0435 \u0438 \u0441\u043f\u0440\u0430\u0432\u0435\u0434\u043b\u0438\u0432\u043e\u0441\u0442\u0438; \u0442\u0435\u043d\u044c \u2014 \u0441\u043e\u0441\u043a\u0430\u043b\u044c\u0437\u044b\u0432\u0430\u043d\u0438\u0435 \u0432 \u0438\u0441\u0444\u0435\u0442, \u0445\u0430\u043e\u0441 \u0438 \u043a\u0440\u0438\u0432\u0434\u0443"
  },
  "core": "\u041b\u0438\u043d\u0437\u0430 \u041c\u0430\u0430\u0442 \u0438 \u0418\u0441\u0444\u0435\u0442: \u043a\u043e\u0441\u043c\u043e\u0441 \u0434\u0435\u0440\u0436\u0438\u0442\u0441\u044f \u043d\u0430 \u0440\u0430\u0432\u043d\u043e\u0432\u0435\u0441\u0438\u0438 \u0438\u0441\u0442\u0438\u043d\u044b \u043f\u0440\u043e\u0442\u0438\u0432 \u0445\u0430\u043e\u0441\u0430; \u0432\u043e\u0441\u0445\u043e\u0436\u0434\u0435\u043d\u0438\u0435 \u2014 \u0432\u0437\u0432\u0435\u0441\u0438\u0442\u044c \u0441\u0435\u0440\u0434\u0446\u0435 \u043d\u0430 \u0432\u0435\u0441\u0430\u0445 \u041c\u0430\u0430\u0442 \u0438 \u0436\u0438\u0442\u044c \u0432 \u0441\u043e\u0433\u043b\u0430\u0441\u0438\u0438 \u0441 \u043f\u043e\u0440\u044f\u0434\u043a\u043e\u043c.",
  "faces": {
    "svet_ra": "\u0420\u0430 \u2014 \u0441\u043e\u043b\u043d\u0435\u0447\u043d\u043e\u0435 \u0431\u043e\u0436\u0435\u0441\u0442\u0432\u043e, \u0438\u0437\u043d\u0430\u0447\u0430\u043b\u044c\u043d\u044b\u0439 \u0441\u0432\u0435\u0442",
    "iskra": "\u0425\u043e\u043d\u0441\u0443 \u2014 \u043b\u0443\u043d\u043d\u044b\u0439 \u0441\u0442\u0440\u0430\u043d\u043d\u0438\u043a, \u0437\u043e\u0432 \u0438 \u0442\u0435\u0447\u0435\u043d\u0438\u0435 \u0432\u0440\u0435\u043c\u0435\u043d\u0438",
    "brahma": "\u041f\u0442\u0430\u0445 \u2014 \u0442\u0432\u043e\u0440\u0435\u0446-\u0434\u0435\u043c\u0438\u0443\u0440\u0433, \u0441\u043e\u0437\u0434\u0430\u0432\u0448\u0438\u0439 \u043c\u0438\u0440 \u0441\u043b\u043e\u0432\u043e\u043c \u0438 \u043c\u044b\u0441\u043b\u044c\u044e",
    "sarasvati": "\u0422\u043e\u0442 \u2014 \u0431\u043e\u0433 \u043f\u0438\u0441\u044c\u043c\u0430, \u0441\u043b\u043e\u0432\u0430, \u0437\u043d\u0430\u043d\u0438\u044f \u0438 \u043c\u0443\u0434\u0440\u043e\u0441\u0442\u0438",
    "vishnu": "\u041e\u0441\u0438\u0440\u0438\u0441 \u2014 \u0432\u043b\u0430\u0434\u044b\u043a\u0430 \u043f\u043e\u0440\u044f\u0434\u043a\u0430, \u043f\u043e\u0434\u0434\u0435\u0440\u0436\u0430\u043d\u0438\u0435 \u0436\u0438\u0437\u043d\u0438 \u0438 \u0432\u043e\u0441\u043a\u0440\u0435\u0441\u0435\u043d\u0438\u0435",
    "lakshmi": "\u0420\u0435\u043d\u0435\u043d\u0443\u0442\u0435\u0442 \u2014 \u0431\u043e\u0433\u0438\u043d\u044f \u0443\u0440\u043e\u0436\u0430\u044f, \u0438\u0437\u043e\u0431\u0438\u043b\u0438\u044f \u0438 \u043f\u0438\u0442\u0430\u043d\u0438\u044f",
    "shiva": "\u0421\u0435\u0442 \u2014 \u0431\u0443\u0440\u044f \u0438 \u0440\u0430\u0437\u0440\u0443\u0448\u0435\u043d\u0438\u0435, \u0445\u0430\u043e\u0442\u0438\u0447\u0435\u0441\u043a\u0430\u044f \u0441\u0438\u043b\u0430 \u043f\u0440\u0435\u043e\u0431\u0440\u0430\u0436\u0435\u043d\u0438\u044f",
    "parvati": "\u0418\u0441\u0438\u0434\u0430 \u2014 \u043c\u0430\u0442\u0435\u0440\u0438\u043d\u0441\u043a\u0430\u044f \u043c\u0430\u0433\u0438\u044f, \u0437\u0430\u0431\u043e\u0442\u0430 \u0438 \u0438\u0441\u0446\u0435\u043b\u0435\u043d\u0438\u0435",
    "jnana": "\u0421\u0438\u0430 \u2014 \u0431\u043e\u0436\u0435\u0441\u0442\u0432\u043e \u043f\u0440\u043e\u0437\u0440\u0435\u043d\u0438\u044f \u0438 \u0440\u0430\u0437\u043b\u0438\u0447\u0430\u044e\u0449\u0435\u0433\u043e \u0440\u0430\u0437\u0443\u043c\u0430",
    "prema": "\u0425\u0430\u0442\u0445\u043e\u0440 \u2014 \u043b\u044e\u0431\u043e\u0432\u044c, \u043a\u0440\u0430\u0441\u043e\u0442\u0430 \u0438 \u043f\u0440\u0435\u0434\u0430\u043d\u043d\u043e\u0441\u0442\u044c \u0441\u0435\u0440\u0434\u0446\u0430",
    "shakti": "\u0421\u0435\u0445\u043c\u0435\u0442 \u2014 \u043b\u044c\u0432\u0438\u043d\u0430\u044f \u0431\u043e\u0433\u0438\u043d\u044f \u0432\u043e\u0439\u043d\u044b, \u044f\u0440\u043e\u0441\u0442\u044c \u0438 \u0432\u043e\u043b\u044f",
    "ananda": "\u0411\u0430\u0441\u0442\u0435\u0442 \u2014 \u0440\u0430\u0434\u043e\u0441\u0442\u044c, \u043c\u0443\u0437\u044b\u043a\u0430 \u0438 \u0431\u043b\u0430\u0436\u0435\u043d\u0441\u0442\u0432\u043e \u043f\u0440\u0430\u0437\u0434\u043d\u0438\u043a\u0430",
    "shanti": "\u041d\u0435\u0444\u0442\u0438\u0434\u0430 \u2014 \u0442\u0438\u0448\u0438\u043d\u0430, \u0441\u0443\u043c\u0435\u0440\u043a\u0438 \u0438 \u0441\u043a\u0440\u044b\u0442\u044b\u0439 \u043f\u043e\u043a\u043e\u0439",
    "agni": "\u0423\u0440\u0435\u0439 \u2014 \u043e\u0433\u043d\u0435\u043d\u043d\u0430\u044f \u043a\u043e\u0431\u0440\u0430 \u041e\u043a\u0430 \u0420\u0430, \u043f\u043b\u0430\u043c\u044f \u043e\u0447\u0438\u0449\u0435\u043d\u0438\u044f \u0438 \u0437\u0430\u0449\u0438\u0442\u044b",
    "vayu": "\u0428\u0443 \u2014 \u0431\u043e\u0433 \u0432\u043e\u0437\u0434\u0443\u0445\u0430, \u0432\u0435\u0442\u0440\u0430 \u0438 \u0434\u044b\u0445\u0430\u043d\u0438\u044f",
    "varuna": "\u041d\u0443\u043d \u2014 \u043f\u0435\u0440\u0432\u043e\u0437\u0434\u0430\u043d\u043d\u044b\u0435 \u0432\u043e\u0434\u044b, \u0433\u043b\u0443\u0431\u0438\u043d\u0430 \u0438 \u043f\u0430\u043c\u044f\u0442\u044c \u0431\u0435\u0437\u0434\u043d\u044b",
    "prithvi": "\u0413\u0435\u0431 \u2014 \u0431\u043e\u0433 \u0437\u0435\u043c\u043b\u0438, \u043e\u043f\u043e\u0440\u0430 \u0438 \u043f\u043b\u043e\u0434\u043e\u0440\u043e\u0434\u0438\u0435 \u043f\u043e\u0447\u0432\u044b",
    "akasha": "\u041d\u0443\u0442 \u2014 \u0431\u043e\u0433\u0438\u043d\u044f \u043d\u0435\u0431\u0430, \u0442\u043a\u0430\u043d\u044c \u043f\u0440\u043e\u0441\u0442\u0440\u0430\u043d\u0441\u0442\u0432\u0430 \u043d\u0430\u0434 \u043c\u0438\u0440\u043e\u043c",
    "tejas": "\u0410\u0442\u043e\u043d \u2014 \u0441\u0438\u044f\u044e\u0449\u0438\u0439 \u0441\u043e\u043b\u043d\u0435\u0447\u043d\u044b\u0439 \u0434\u0438\u0441\u043a, \u0431\u043b\u0435\u0441\u043a \u043b\u0443\u0447\u0435\u0439",
    "dharma": "\u041c\u0430\u0430\u0442 \u2014 \u0431\u043e\u0433\u0438\u043d\u044f \u0438\u0441\u0442\u0438\u043d\u044b, \u0437\u0430\u043a\u043e\u043d\u0430 \u0438 \u043a\u043e\u0441\u043c\u0438\u0447\u0435\u0441\u043a\u043e\u0433\u043e \u0434\u043e\u043b\u0433\u0430",
    "karma": "\u0412\u0435\u0441\u044b \u0441\u0435\u0440\u0434\u0446\u0430 \u0438 \u0410\u043c\u043c\u0430\u0442 \u2014 \u0432\u043e\u0437\u0434\u0430\u044f\u043d\u0438\u0435, \u043f\u0440\u0438\u0447\u0438\u043d\u0430 \u0438 \u0441\u043b\u0435\u0434\u0441\u0442\u0432\u0438\u0435 \u0434\u0435\u044f\u043d\u0438\u0439"
  },
  "resonance_keywords": ["\u041c\u0430\u0430\u0442", "\u0418\u0441\u0444\u0435\u0442", "\u0414\u0443\u0430\u0442", "\u0420\u0430", "\u0432\u0435\u0441\u044b \u0441\u0435\u0440\u0434\u0446\u0430", "\u0438\u0435\u0440\u043e\u0433\u043b\u0438\u0444\u044b", "\u041d\u0438\u043b", "\u041e\u043a\u043e \u0413\u043e\u0440\u0430", "\u0437\u0430\u0433\u0440\u043e\u0431\u043d\u044b\u0439 \u0441\u0443\u0434", "\u0432\u0435\u0447\u043d\u043e\u0441\u0442\u044c"],
  "visual_code": "\u041b\u0430\u0437\u0443\u0440\u0438\u0442 \u0438 \u0437\u043e\u043b\u043e\u0442\u043e, \u0447\u0451\u0440\u043d\u044b\u0439 \u0431\u0430\u0437\u0430\u043b\u044c\u0442, \u0438\u0435\u0440\u043e\u0433\u043b\u0438\u0444\u044b \u0438 \u0441\u043e\u043b\u043d\u0435\u0447\u043d\u0430\u044f \u043b\u0430\u0434\u044c\u044f \u0420\u0430, \u0437\u0432\u0435\u0437\u0434\u0430 \u0421\u0438\u0440\u0438\u0443\u0441, \u041e\u043a\u043e \u0413\u043e\u0440\u0430 \u0438 \u0432\u0435\u0441\u044b \u0432\u0437\u0432\u0435\u0448\u0438\u0432\u0430\u043d\u0438\u044f \u0441\u0435\u0440\u0434\u0446\u0430",
