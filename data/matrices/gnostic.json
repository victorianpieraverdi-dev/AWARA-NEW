{
  "matrix_slug": "gnostic",
  "matrix_name": "\u0413\u043d\u043e\u0441\u0442\u0438\u0447\u0435\u0441\u043a\u0430\u044f",
  "element_accent": "\u042d\u0444\u0438\u0440",
  "chakra_accent": "\u0421\u0430\u0445\u0430\u0441\u0440\u0430\u0440\u0430",
  "guna_accent": "\u0441\u0430\u0442\u0442\u0432\u0430",
  "graha_accent": "\u0421\u043e\u043b\u043d\u0446\u0435",
  "pole": {
    "toward": "\u0413\u043d\u043e\u0437\u0438\u0441 \u2014 \u043f\u0440\u043e\u0431\u0443\u0436\u0434\u0435\u043d\u0438\u0435 \u0438\u0441\u043a\u0440\u044b, \u043f\u0440\u0438\u043f\u043e\u043c\u0438\u043d\u0430\u043d\u0438\u0435 \u043d\u0435\u0431\u0435\u0441\u043d\u043e\u0433\u043e \u0438\u0441\u0442\u043e\u043a\u0430 \u0438 \u0432\u043e\u0441\u0445\u043e\u0436\u0434\u0435\u043d\u0438\u0435 \u0441\u043a\u0432\u043e\u0437\u044c \u0430\u0440\u0445\u043e\u043d\u0442\u043e\u0432 \u043a \u041f\u043b\u0435\u0440\u043e\u043c\u0435",
    "away": "\u0410\u0440\u0445\u043e\u043d\u0442\u0441\u043a\u0438\u0439 \u0441\u043e\u043d \u2014 \u0437\u0430\u0431\u0432\u0435\u043d\u0438\u0435 \u0432 \u043c\u0430\u0442\u0435\u0440\u0438\u0438, \u043f\u043b\u0435\u043d \u0414\u0435\u043c\u0438\u0443\u0440\u0433\u0430 \u0438 \u0440\u043e\u043a\u0430, \u043e\u0442\u043e\u0436\u0434\u0435\u0441\u0442\u0432\u043b\u0435\u043d\u0438\u0435 \u0441 \u0442\u0435\u043b\u043e\u043c-\u0442\u0435\u043c\u043d\u0438\u0446\u0435\u0439",
    "note": "\u0421\u0432\u0435\u0442 \u2014 \u043f\u0440\u043e\u0431\u0443\u0434\u0438\u0442\u044c\u0441\u044f \u043a \u0433\u043d\u043e\u0437\u0438\u0441\u0443 \u0438 \u0432\u0435\u0440\u043d\u0443\u0442\u044c \u0438\u0441\u043a\u0440\u0443 \u0432 \u041f\u043b\u0435\u0440\u043e\u043c\u0443; \u0442\u0435\u043d\u044c \u2014 \u0443\u0441\u043d\u0443\u0442\u044c \u0432 \u043d\u0435\u0432\u0435\u0434\u0435\u043d\u0438\u0438 \u043f\u043e\u0434 \u0432\u043b\u0430\u0441\u0442\u044c\u044e \u0430\u0440\u0445\u043e\u043d\u0442\u043e\u0432 \u0438 \u0440\u043e\u043a\u0430"
  },
  "core": "\u041b\u0438\u043d\u0437\u0430 \u0433\u043d\u043e\u0437\u0438\u0441\u0430 \u0438 \u0430\u0440\u0445\u043e\u043d\u0442\u0441\u043a\u043e\u0433\u043e \u0441\u043d\u0430: \u043c\u0438\u0440 \u2014 \u0442\u0435\u043c\u043d\u0438\u0446\u0430 \u043c\u0430\u0442\u0435\u0440\u0438\u0438, \u043a\u0443\u0434\u0430 \u043f\u0430\u043b\u0430 \u0438\u0441\u043a\u0440\u0430 \u0441\u0432\u0435\u0442\u0430; \u0432\u043e\u0441\u0445\u043e\u0436\u0434\u0435\u043d\u0438\u0435 \u2014 \u043f\u0440\u043e\u0431\u0443\u0434\u0438\u0442\u044c\u0441\u044f, \u043f\u043e\u0437\u043d\u0430\u0442\u044c \u0441\u0432\u043e\u0439 \u0438\u0441\u0442\u0438\u043d\u043d\u044b\u0439 \u0438\u0441\u0442\u043e\u043a \u0438 \u0432\u0435\u0440\u043d\u0443\u0442\u044c\u0441\u044f \u0447\u0435\u0440\u0435\u0437 \u044d\u043e\u043d\u044b \u0432 \u041f\u043b\u0435\u0440\u043e\u043c\u0443.",
  "faces": {
    "svet_ra": "\u0411\u0438\u0442\u043e\u0441 \u2014 \u043d\u0435\u043f\u043e\u0437\u043d\u0430\u0432\u0430\u0435\u043c\u044b\u0439 \u041e\u0442\u0435\u0446-\u0413\u043b\u0443\u0431\u0438\u043d\u0430, \u0438\u0441\u0442\u043e\u043a \u041f\u043b\u0435\u0440\u043e\u043c\u044b",
    "iskra": "\u0411\u043e\u0436\u0435\u0441\u0442\u0432\u0435\u043d\u043d\u0430\u044f \u0418\u0441\u043a\u0440\u0430 \u2014 \u0447\u0430\u0441\u0442\u0438\u0446\u0430 \u0441\u0432\u0435\u0442\u0430, \u043f\u043b\u0435\u043d\u0435\u043d\u043d\u0430\u044f \u0432 \u043c\u0430\u0442\u0435\u0440\u0438\u0438, \u0437\u043e\u0432 \u043a \u043f\u0440\u043e\u0431\u0443\u0436\u0434\u0435\u043d\u0438\u044e",
    "brahma": "\u0414\u0435\u043c\u0438\u0443\u0440\u0433 (\u042f\u043b\u0434\u0430\u0432\u0430\u043e\u0444) \u2014 \u043b\u043e\u0436\u043d\u044b\u0439 \u0442\u0432\u043e\u0440\u0435\u0446 \u043c\u0430\u0442\u0435\u0440\u0438\u0430\u043b\u044c\u043d\u043e\u0433\u043e \u043c\u0438\u0440\u0430 \u0444\u043e\u0440\u043c",
    "sarasvati": "\u041b\u043e\u0433\u043e\u0441 \u2014 \u0431\u043e\u0436\u0435\u0441\u0442\u0432\u0435\u043d\u043d\u043e\u0435 \u0421\u043b\u043e\u0432\u043e, \u0443\u043f\u043e\u0440\u044f\u0434\u043e\u0447\u0438\u0432\u0430\u044e\u0449\u0435\u0435 \u041f\u043b\u0435\u0440\u043e\u043c\u0443",
    "vishnu": "\u0425\u0440\u0438\u0441\u0442\u043e\u0441 \u2014 \u043d\u0435\u0431\u0435\u0441\u043d\u044b\u0439 \u0438\u0441\u043a\u0443\u043f\u0438\u0442\u0435\u043b\u044c, \u0445\u0440\u0430\u043d\u044f\u0449\u0438\u0439 \u0441\u0432\u044f\u0437\u044c \u0438\u0441\u043a\u0440 \u0441 \u041f\u043b\u0435\u0440\u043e\u043c\u043e\u0439",
    "lakshmi": "\u041f\u043b\u0435\u0440\u043e\u043c\u0430 \u2014 \u043f\u043e\u043b\u043d\u043e\u0442\u0430 \u0438 \u0438\u0437\u043e\u0431\u0438\u043b\u0438\u0435 \u0431\u043e\u0436\u0435\u0441\u0442\u0432\u0435\u043d\u043d\u043e\u0433\u043e \u043c\u0438\u0440\u0430 \u044d\u043e\u043d\u043e\u0432",
    "shiva": "\u0410\u0440\u0445\u043e\u043d\u0442\u044b \u2014 \u0442\u044e\u0440\u0435\u043c\u0449\u0438\u043a\u0438 \u043c\u0430\u0442\u0435\u0440\u0438\u0438, \u043f\u043e\u043c\u0440\u0430\u0447\u0435\u043d\u0438\u0435 \u0438 \u0440\u0430\u0437\u0440\u0443\u0448\u0435\u043d\u0438\u0435 \u0434\u0443\u0448",
    "parvati": "\u0411\u0430\u0440\u0431\u0435\u043b\u043e \u2014 \u043f\u0435\u0440\u0432\u0430\u044f \u044d\u043c\u0430\u043d\u0430\u0446\u0438\u044f, \u041c\u0430\u0442\u044c-\u041f\u0440\u043e\u043d\u043e\u0439\u044f, \u0437\u0430\u0431\u043e\u0442\u0430 \u0438 \u043f\u0440\u043e\u043c\u044b\u0441\u043b",
    "jnana": "\u0421\u043e\u0444\u0438\u044f \u2014 \u043f\u0440\u0435\u043c\u0443\u0434\u0440\u043e\u0441\u0442\u044c, \u0447\u044c\u0451 \u0443\u0441\u0442\u0440\u0435\u043c\u043b\u0435\u043d\u0438\u0435 \u043a \u0418\u0441\u0442\u043e\u043a\u0443 \u0440\u043e\u0436\u0434\u0430\u0435\u0442 \u0433\u043d\u043e\u0437\u0438\u0441 \u0438 \u0440\u0430\u0437\u043b\u0438\u0447\u0435\u043d\u0438\u0435",
    "prema": "\u0410\u0433\u0430\u043f\u044d \u2014 \u044d\u043e\u043d \u041b\u044e\u0431\u0432\u0438, \u0432\u043b\u0435\u043a\u0443\u0449\u0438\u0439 \u0438\u0441\u043a\u0440\u044b \u043d\u0430\u0437\u0430\u0434 \u043a \u041f\u043b\u0435\u0440\u043e\u043c\u0435",
    "shakti": "\u0414\u0438\u043d\u0430\u043c\u0438\u0441 \u2014 \u044d\u043e\u043d \u0431\u043e\u0436\u0435\u0441\u0442\u0432\u0435\u043d\u043d\u043e\u0439 \u0421\u0438\u043b\u044b \u0438 \u043c\u043e\u0449\u0438",
    "ananda": "\u0411\u043b\u0430\u0436\u0435\u043d\u0441\u0442\u0432\u043e \u041f\u043b\u0435\u0440\u043e\u043c\u044b \u2014 \u0440\u0430\u0434\u043e\u0441\u0442\u044c \u043f\u043e\u043b\u043d\u043e\u0442\u044b \u0432\u043e\u0441\u0441\u043e\u0435\u0434\u0438\u043d\u0451\u043d\u043d\u044b\u0445 \u044d\u043e\u043d\u043e\u0432",
    "shanti": "\u0421\u0438\u0433\u0435 \u2014 \u041c\u043e\u043b\u0447\u0430\u043d\u0438\u0435, \u0431\u0435\u0437\u043c\u043e\u043b\u0432\u043d\u044b\u0439 \u043f\u043e\u043a\u043e\u0439 \u043f\u0440\u0438 \u0413\u043b\u0443\u0431\u0438\u043d\u0435-\u041e\u0442\u0446\u0435",
    "agni": "\u041f\u043b\u0430\u043c\u044f \u0414\u0443\u0445\u0430 \u2014 \u043e\u0447\u0438\u0441\u0442\u0438\u0442\u0435\u043b\u044c\u043d\u044b\u0439 \u043e\u0433\u043e\u043d\u044c \u0433\u043d\u043e\u0437\u0438\u0441\u0430, \u043a\u0440\u0435\u0449\u0435\u043d\u0438\u0435 \u0441\u0432\u0435\u0442\u043e\u043c",
    "vayu": "\u041f\u043d\u0435\u0432\u043c\u0430 \u2014 \u0421\u0432\u044f\u0442\u043e\u0439 \u0414\u0443\u0445, \u0434\u044b\u0445\u0430\u043d\u0438\u0435 \u041f\u043b\u0435\u0440\u043e\u043c\u044b",
    "varuna": "\u0410\u043d\u0430\u043c\u043d\u0435\u0437\u0438\u0441 \u2014 \u043f\u0440\u0438\u043f\u043e\u043c\u0438\u043d\u0430\u043d\u0438\u0435 \u043d\u0435\u0431\u0435\u0441\u043d\u043e\u0433\u043e \u0438\u0441\u0442\u043e\u043a\u0430, \u043f\u0430\u043c\u044f\u0442\u044c \u0438\u0441\u043a\u0440\u044b",
    "prithvi": "\u0413\u0438\u043b\u044d \u2014 \u043f\u043b\u043e\u0442\u043d\u0430\u044f \u0442\u0432\u0435\u0440\u0434\u044c \u043c\u0430\u0442\u0435\u0440\u0438\u0438, \u043e\u043f\u043e\u0440\u0430 \u0438 \u0442\u0435\u043c\u043d\u0438\u0446\u0430 \u0434\u043b\u044f \u0438\u0441\u043a\u0440",
    "akasha": "\u0410\u0439\u043e\u043d \u2014 \u0431\u0435\u0441\u043f\u0440\u0435\u0434\u0435\u043b\u044c\u043d\u0430\u044f \u0432\u0435\u0447\u043d\u043e\u0441\u0442\u044c-\u043f\u0440\u043e\u0441\u0442\u0440\u0430\u043d\u0441\u0442\u0432\u043e \u041f\u043b\u0435\u0440\u043e\u043c\u044b",
    "tejas": "\u0410\u0434\u0430\u043c\u0430\u0441 \u2014 \u043d\u0435\u0431\u0435\u0441\u043d\u044b\u0439 \u0441\u0432\u0435\u0442\u043e\u043d\u043e\u0441\u043d\u044b\u0439 \u0427\u0435\u043b\u043e\u0432\u0435\u043a, \u0441\u0438\u044f\u043d\u0438\u0435 \u043f\u0435\u0440\u0432\u043e\u043e\u0431\u0440\u0430\u0437\u0430",
    "dharma": "\u041e\u0440\u043e\u0441 \u2014 \u041f\u0440\u0435\u0434\u0435\u043b, \u0433\u0440\u0430\u043d\u0438\u0446\u0430 \u041f\u043b\u0435\u0440\u043e\u043c\u044b, \u0445\u0440\u0430\u043d\u044f\u0449\u0430\u044f \u0437\u0430\u043a\u043e\u043d \u0438 \u0441\u0442\u0440\u043e\u0439 \u044d\u043e\u043d\u043e\u0432",
    "karma": "\u0425\u0435\u0439\u043c\u0430\u0440\u043c\u0435\u043d\u0435 \u2014 \u0440\u043e\u043a \u0430\u0440\u0445\u043e\u043d\u0442\u043e\u0432, \u0446\u0435\u043f\u044c \u043f\u0440\u0438\u0447\u0438\u043d \u0438 \u0441\u043b\u0435\u0434\u0441\u0442\u0432\u0438\u0439 \u043c\u0430\u0442\u0435\u0440\u0438\u0438"
  },
  "resonance_keywords": ["\u0433\u043d\u043e\u0437\u0438\u0441", "\u041f\u043b\u0435\u0440\u043e\u043c\u0430", "\u0421\u043e\u0444\u0438\u044f", "\u0438\u0441\u043a\u0440\u0430", "\u0430\u0440\u0445\u043e\u043d\u0442\u044b", "\u0414\u0435\u043c\u0438\u0443\u0440\u0433", "\u044d\u043e\u043d\u044b", "\u043f\u0440\u043e\u0431\u0443\u0436\u0434\u0435\u043d\u0438\u0435", "\u0411\u0430\u0440\u0431\u0435\u043b\u043e", "\u041b\u043e\u0433\u043e\u0441"],
  "visual_code": "\u043f\u0430\u0434\u0430\u044e\u0449\u0430\u044f \u0438\u0441\u043a\u0440\u0430 \u0441\u0432\u0435\u0442\u0430 \u0441\u043a\u0432\u043e\u0437\u044c \u0442\u044c\u043c\u0443, \u0446\u0435\u043f\u0438 \u0438 \u0442\u0435\u043c\u043d\u0438\u0446\u0430 \u043c\u0430\u0442\u0435\u0440\u0438\u0438, \u0441\u043f\u0438\u0440\u0430\u043b\u0438 \u044d\u043e\u043d\u043e\u0432, \u043e\u043a\u043e \u0414\u0435\u043c\u0438\u0443\u0440\u0433\u0430, \u0437\u043c\u0435\u0439-\u0443\u0440\u043e\u0431\u043e\u0440\u043e\u0441 \u0433\u043d\u043e\u0437\u0438\u0441\u0430, \u043b\u0443\u0447\u0438 \u041f\u043b\u0435\u0440\u043e\u043c\u044b, \u0440\u0430\u0437\u043e\u0440\u0432\u0430\u043d\u043d\u044b\u0435 \u043e\u043a\u043e\u0432\u044b",
  "sources": ["https://en.wikipedia.org/wiki/Gnosticism", "https://en.wikipedia.org/wiki/Sophia_(Gnosticism)", "https://en.wikipedia.org/wiki/Pleroma", "https://en.wikipedia.org/wiki/Demiurge", "https://en.wikipedia.org/wiki/Aeon_(Gnosticism)", "https://en.wikipedia.org/wiki/Yaldabaoth"]
}
