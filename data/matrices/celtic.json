{
  "matrix_slug": "celtic",
  "matrix_name": "\u041a\u0435\u043b\u044c\u0442\u0441\u043a\u0430\u044f",
  "element_accent": "\u0417\u0435\u043c\u043b\u044f",
  "chakra_accent": "\u0412\u0438\u0448\u0443\u0434\u0434\u0445\u0430",
  "guna_accent": "\u0440\u0430\u0434\u0436\u0430\u0441",
  "graha_accent": "\u041b\u0443\u043d\u0430",
  "pole": {
    "toward": "\u0410\u0432\u0435\u043d \u2014 \u043f\u043e\u0442\u043e\u043a \u0431\u043e\u0436\u0435\u0441\u0442\u0432\u0435\u043d\u043d\u043e\u0433\u043e \u0432\u0434\u043e\u0445\u043d\u043e\u0432\u0435\u043d\u0438\u044f, \u044f\u0441\u043d\u043e\u0435 \u0432\u0438\u0434\u0435\u043d\u0438\u0435 \u0438 \u0441\u0432\u044f\u0437\u044c \u0441 \u0418\u043d\u044b\u043c \u043c\u0438\u0440\u043e\u043c",
    "away": "\u0422\u0443\u043c\u0430\u043d \u2014 \u043a\u0435\u043b\u044c\u0442\u0441\u043a\u0438\u0439 \u043c\u043e\u0440\u043e\u043a, \u0437\u0430\u0431\u0432\u0435\u043d\u0438\u0435 \u0438 \u043f\u043e\u0442\u0435\u0440\u044f \u043f\u0443\u0442\u0438 \u0432 \u0418\u043d\u043e\u043c \u043c\u0438\u0440\u0435",
    "note": "\u0421\u0432\u0435\u0442 \u2014 \u043f\u0438\u0442\u044c \u0438\u0437 \u043a\u043e\u0442\u043b\u0430 \u0410\u0432\u0435\u043d\u0430, \u0432\u0438\u0434\u0435\u0442\u044c \u0441\u043a\u0432\u043e\u0437\u044c \u0442\u0443\u043c\u0430\u043d \u0438 \u0434\u0435\u0440\u0436\u0430\u0442\u044c \u0433\u0435\u0439\u0441\u044b; \u0442\u0435\u043d\u044c \u2014 \u0437\u0430\u0431\u043b\u0443\u0434\u0438\u0442\u044c\u0441\u044f \u0432 \u0442\u0443\u043c\u0430\u043d\u0435, \u0443\u0442\u0440\u0430\u0442\u0438\u0442\u044c \u0432\u0434\u043e\u0445\u043d\u043e\u0432\u0435\u043d\u0438\u0435 \u0438 \u043d\u0430\u0440\u0443\u0448\u0438\u0442\u044c \u043e\u0431\u0435\u0442\u044b"
  },
  "core": "\u041b\u0438\u043d\u0437\u0430 \u0410\u0432\u0435\u043d\u0430 \u0438 \u0442\u0443\u043c\u0430\u043d\u0430: \u043c\u0438\u0440 \u043f\u0440\u043e\u043d\u0438\u0437\u0430\u043d \u0418\u043d\u044b\u043c \u043c\u0438\u0440\u043e\u043c, \u043e\u0442\u043a\u0443\u0434\u0430 \u0442\u0435\u0447\u0451\u0442 \u0432\u0434\u043e\u0445\u043d\u043e\u0432\u0435\u043d\u0438\u0435; \u0432\u043e\u0441\u0445\u043e\u0436\u0434\u0435\u043d\u0438\u0435 \u2014 \u043e\u0442\u043a\u0440\u044b\u0442\u044c \u0410\u0432\u0435\u043d, \u043f\u0440\u043e\u0439\u0442\u0438 \u0441\u043a\u0432\u043e\u0437\u044c \u0442\u0443\u043c\u0430\u043d \u0441\u0438\u0434\u043e\u0432 \u0438 \u0436\u0438\u0442\u044c \u0432 \u0441\u043e\u0433\u043b\u0430\u0441\u0438\u0438 \u0441 \u0433\u0435\u0439\u0441\u0430\u043c\u0438, \u043d\u0435\u0441\u044f \u0441\u0432\u0435\u0442 \u0432 \u043e\u0431\u0435 \u0441\u0442\u043e\u0440\u043e\u043d\u044b \u0437\u0430\u0432\u0435\u0441\u044b.",
  "faces": {
    "svet_ra": "\u0411\u0435\u043b\u0435\u043d\u043e\u0441 \u2014 \u0441\u043e\u043b\u043d\u0435\u0447\u043d\u044b\u0439 \u0431\u043e\u0433 \u0441\u0432\u0435\u0442\u0430, \u0438\u0441\u0442\u043e\u043a \u0441\u0438\u044f\u043d\u0438\u044f \u0434\u043d\u044f",
    "iskra": "\u0410\u0440\u0438\u0430\u043d\u0440\u043e\u0434 \u2014 \u0431\u043e\u0433\u0438\u043d\u044f \u043b\u0443\u043d\u044b \u0438 \u0441\u0435\u0440\u0435\u0431\u0440\u044f\u043d\u043e\u0433\u043e \u0437\u0432\u0451\u0437\u0434\u043d\u043e\u0433\u043e \u043a\u043e\u043b\u0435\u0441\u0430, \u0437\u043e\u0432 \u043d\u043e\u0447\u0438",
    "brahma": "\u0414\u0430\u043d\u0443 \u2014 \u0431\u043e\u0433\u0438\u043d\u044f-\u043c\u0430\u0442\u044c, \u043f\u0440\u0430\u0440\u043e\u0434\u0438\u0442\u0435\u043b\u044c\u043d\u0438\u0446\u0430 \u043f\u043b\u0435\u043c\u0451\u043d \u0431\u043e\u0433\u043e\u0432, \u0438\u0441\u0442\u043e\u043a \u0444\u043e\u0440\u043c",
    "sarasvati": "\u041e\u0433\u043c\u0430 \u2014 \u0431\u043e\u0433 \u043a\u0440\u0430\u0441\u043d\u043e\u0440\u0435\u0447\u0438\u044f \u0438 \u043e\u0433\u0430\u043c\u0438\u0447\u0435\u0441\u043a\u043e\u0433\u043e \u043f\u0438\u0441\u044c\u043c\u0430, \u0432\u043b\u0430\u0434\u044b\u043a\u0430 \u0441\u043b\u043e\u0432\u0430",
    "vishnu": "\u0414\u0430\u0433\u0434\u0430 \u2014 \u0434\u043e\u0431\u0440\u044b\u0439 \u0431\u043e\u0433-\u043e\u0442\u0435\u0446, \u0432\u043b\u0430\u0434\u044b\u043a\u0430 \u043a\u043e\u0442\u043b\u0430, \u0434\u0435\u0440\u0436\u0430\u0449\u0438\u0439 \u043c\u0438\u0440\u043e\u043f\u043e\u0440\u044f\u0434\u043e\u043a",
    "lakshmi": "\u041a\u043e\u0442\u0451\u043b \u0414\u0430\u0433\u0434\u044b \u2014 \u043d\u0435\u0438\u0441\u0441\u044f\u043a\u0430\u0435\u043c\u044b\u0439 \u0438\u0441\u0442\u043e\u0447\u043d\u0438\u043a \u043f\u0438\u0449\u0438 \u0438 \u0438\u0437\u043e\u0431\u0438\u043b\u0438\u044f",
    "shiva": "\u0411\u0430\u043b\u043e\u0440 \u2014 \u043a\u043e\u0440\u043e\u043b\u044c \u0444\u043e\u043c\u043e\u0440\u043e\u0432 \u0441 \u0433\u0443\u0431\u0438\u0442\u0435\u043b\u044c\u043d\u044b\u043c \u0433\u043b\u0430\u0437\u043e\u043c, \u0440\u0430\u0437\u0440\u0443\u0448\u0435\u043d\u0438\u0435",
    "parvati": "\u0411\u0440\u0438\u0433\u0438\u0442\u0430 \u2014 \u0431\u043e\u0433\u0438\u043d\u044f \u043e\u0447\u0430\u0433\u0430, \u0438\u0441\u0446\u0435\u043b\u0435\u043d\u0438\u044f \u0438 \u0437\u0430\u0431\u043e\u0442\u044b",
    "jnana": "\u041a\u0435\u0440\u0438\u0434\u0432\u0435\u043d \u2014 \u0445\u0440\u0430\u043d\u0438\u0442\u0435\u043b\u044c\u043d\u0438\u0446\u0430 \u043a\u043e\u0442\u043b\u0430 \u043c\u0443\u0434\u0440\u043e\u0441\u0442\u0438, \u0440\u043e\u0436\u0434\u0430\u044e\u0449\u0430\u044f \u0410\u0432\u0435\u043d \u0438 \u0440\u0430\u0437\u043b\u0438\u0447\u0435\u043d\u0438\u0435",
    "prema": "\u042d\u043d\u0433\u0443\u0441 \u2014 \u044e\u043d\u044b\u0439 \u0431\u043e\u0433 \u043b\u044e\u0431\u0432\u0438 \u0438 \u0432\u0434\u043e\u0445\u043d\u043e\u0432\u043b\u0451\u043d\u043d\u043e\u0439 \u0441\u0442\u0440\u0430\u0441\u0442\u0438",
    "shakti": "\u041d\u0435\u0439\u0442 \u2014 \u0434\u0440\u0435\u0432\u043d\u0438\u0439 \u0431\u043e\u0433 \u0432\u043e\u0439\u043d\u044b \u0438 \u044f\u0440\u043e\u0441\u0442\u043d\u043e\u0439 \u0441\u0438\u043b\u044b",
    "ananda": "\u041f\u0438\u0440 \u0413\u043e\u0438\u0431\u043d\u0438\u0443 \u2014 \u0445\u043c\u0435\u043b\u044c\u043d\u043e\u0439 \u043f\u0438\u0440 \u0431\u0435\u0441\u0441\u043c\u0435\u0440\u0442\u043d\u044b\u0445, \u0431\u043b\u0430\u0436\u0435\u043d\u0441\u0442\u0432\u043e \u0418\u043d\u043e\u0433\u043e \u043c\u0438\u0440\u0430",
    "shanti": "\u0422\u0438\u0440 \u043d\u0430 \u041d\u043e\u0433 \u2014 \u0441\u0442\u0440\u0430\u043d\u0430 \u0432\u0435\u0447\u043d\u043e\u0439 \u044e\u043d\u043e\u0441\u0442\u0438, \u043f\u043e\u043a\u043e\u0439 \u0437\u0430 \u043c\u043e\u0440\u0435\u043c",
    "agni": "\u041e\u0433\u043d\u0438 \u0411\u0435\u043b\u044c\u0442\u0430\u0439\u043d\u0430 \u2014 \u0441\u0432\u044f\u0449\u0435\u043d\u043d\u044b\u0435 \u043a\u043e\u0441\u0442\u0440\u044b, \u043e\u0447\u0438\u0441\u0442\u0438\u0442\u0435\u043b\u044c\u043d\u044b\u0439 \u043e\u0433\u043e\u043d\u044c \u0436\u0438\u0437\u043d\u0438",
    "vayu": "\u0413\u0432\u0438\u0434\u0438\u043e\u043d \u2014 \u0431\u043e\u0433-\u0447\u0430\u0440\u043e\u0434\u0435\u0439 \u043d\u0435\u0431\u0430, \u043f\u043b\u0435\u0442\u0443\u0449\u0438\u0439 \u0447\u0430\u0440\u044b \u0438\u0437 \u0432\u0435\u0442\u0440\u0430",
    "varuna": "\u041c\u0430\u043d\u0430\u043d\u043d\u0430\u043d \u043c\u0430\u043a \u041b\u0438\u0440 \u2014 \u0431\u043e\u0433 \u043c\u043e\u0440\u044f \u0438 \u0442\u0443\u043c\u0430\u043d\u043e\u0432, \u0445\u0440\u0430\u043d\u0438\u0442\u0435\u043b\u044c \u043f\u0430\u043c\u044f\u0442\u0438 \u0418\u043d\u043e\u0433\u043e \u043c\u0438\u0440\u0430",
    "prithvi": "\u042d\u0440\u0438\u0443 \u2014 \u0431\u043e\u0433\u0438\u043d\u044f-\u0437\u0435\u043c\u043b\u044f \u0418\u0440\u043b\u0430\u043d\u0434\u0438\u0438, \u043e\u043f\u043e\u0440\u0430 \u043e\u0441\u0442\u0440\u043e\u0432\u0430",
    "akasha": "\u041c\u0430\u0433 \u041c\u0435\u043b\u043b \u2014 \u0431\u0435\u0441\u043a\u0440\u0430\u0439\u043d\u044f\u044f \u0440\u0430\u0432\u043d\u0438\u043d\u0430 \u0431\u043b\u0430\u0436\u0435\u043d\u0441\u0442\u0432\u0430, \u043f\u0440\u043e\u0441\u0442\u043e\u0440 \u0418\u043d\u043e\u0433\u043e \u043c\u0438\u0440\u0430",
    "tejas": "\u041b\u0443\u0433 \u2014 \u0441\u0438\u044f\u044e\u0449\u0438\u0439 \u043c\u043d\u043e\u0433\u043e\u0443\u043c\u0435\u043b\u044b\u0439 \u0431\u043e\u0433 \u0441\u0432\u0435\u0442\u0430 \u0438 \u043c\u0430\u0441\u0442\u0435\u0440\u0441\u0442\u0432\u0430",
    "dharma": "\u0413\u0435\u0439\u0441\u044b \u2014 \u0441\u0432\u044f\u0449\u0435\u043d\u043d\u044b\u0435 \u043e\u0431\u0435\u0442\u044b \u0438 \u0437\u0430\u043f\u0440\u0435\u0442\u044b, \u0437\u0430\u043a\u043e\u043d \u0441\u0443\u0434\u044c\u0431\u044b \u0438 \u0434\u043e\u043b\u0433\u0430",
    "karma": "\u041c\u043e\u0440\u0440\u0438\u0433\u0430\u043d \u2014 \u0431\u043e\u0433\u0438\u043d\u044f \u0441\u0443\u0434\u044c\u0431\u044b \u0438 \u0432\u043e\u0439\u043d\u044b, \u0442\u043a\u0443\u0449\u0430\u044f \u0440\u043e\u043a \u043f\u0440\u0438\u0447\u0438\u043d \u0438 \u0441\u043b\u0435\u0434\u0441\u0442\u0432\u0438\u0439"
  },
  "resonance_keywords": ["\u0410\u0432\u0435\u043d", "\u0441\u0438\u0434\u044b", "\u0422\u0443\u0430\u0442\u0430 \u0414\u0435 \u0414\u0430\u043d\u0430\u043d\u043d", "\u043a\u043e\u0442\u0451\u043b", "\u0433\u0435\u0439\u0441", "\u0418\u043d\u043e\u0439 \u043c\u0438\u0440", "\u0434\u0440\u0443\u0438\u0434\u044b", "\u0421\u0430\u043c\u0430\u0439\u043d", "\u0442\u0443\u043c\u0430\u043d", "\u0410\u0432\u0430\u043b\u043e\u043d"],
  "visual_code": "\u043a\u0435\u043b\u044c\u0442\u0441\u043a\u0438\u0435 \u0443\u0437\u043b\u044b \u0431\u0435\u0437 \u043a\u043e\u043d\u0446\u0430, \u043a\u043e\u0442\u0451\u043b \u0441 \u043f\u0430\u0440\u044f\u0449\u0438\u043c \u0410\u0432\u0435\u043d\u043e\u043c, \u0442\u0443\u043c\u0430\u043d \u043d\u0430\u0434 \u0445\u043e\u043b\u043c\u0430\u043c\u0438-\u0441\u0438\u0434\u0430\u043c\u0438, \u043e\u0441\u0442\u0440\u043e\u0432 \u0410\u0432\u0430\u043b\u043e\u043d \u0432 \u043e\u0437\u0435\u0440\u0435, \u0434\u0443\u0431 \u0438 \u0442\u0440\u0438\u043b\u0438\u0441\u0442\u043d\u0438\u043a, \u0441\u0435\u0440\u0435\u0431\u0440\u044f\u043d\u0430\u044f \u0440\u0443\u043a\u0430 \u041d\u0443\u0430\u0434\u044b, \u0441\u043f\u0438\u0440\u0430\u043b\u0438 \u041d\u044c\u044e\u0433\u0440\u0435\u0439\u043d\u0434\u0436\u0430, \u0432\u043e\u0440\u043e\u043d \u041c\u043e\u0440\u0440\u0438\u0433\u0430\u043d",
  "sources": ["https://en.wikipedia.org/wiki/Celtic_mythology", "https://en.wikipedia.org/wiki/Tuatha_D\u00e9_Danann", "https://en.wikipedia.org/wiki/Awen", "https://en.wikipedia.org/wiki/Cerridwen", "https://en.wikipedia.org/wiki/The_Dagda", "https://en.wikipedia.org/wiki/T\u00edr_na_n\u00d3g"]
