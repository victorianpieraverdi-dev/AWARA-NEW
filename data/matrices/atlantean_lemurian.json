{
  "matrix_slug": "atlantean_lemurian",
  "matrix_name": "\u0410\u0442\u043b\u0430\u043d\u0442\u043e-\u041b\u0435\u043c\u0443\u0440\u0438\u0439\u0441\u043a\u0430\u044f AWARA",
  "element_accent": "\u0412\u043e\u0434\u0430",
  "chakra_accent": "\u0412\u0438\u0448\u0443\u0434\u0434\u0445\u0430",
  "guna_accent": "\u0440\u0430\u0434\u0436\u0430\u0441",
  "graha_accent": "\u041b\u0443\u043d\u0430",
  "pole": {
    "toward": "\u041a\u0440\u0438\u0441\u0442\u0430\u043b\u043b \u2014 \u0433\u0430\u0440\u043c\u043e\u043d\u0438\u044f \u0417\u0430\u043a\u043e\u043d\u0430 \u041e\u0434\u043d\u043e\u0433\u043e, \u0441\u0432\u0435\u0442 \u0432 \u0441\u043e\u0437\u0432\u0443\u0447\u0438\u0438",
    "away": "\u0413\u0438\u0431\u0440\u0438\u0441 \u2014 \u0433\u043e\u0440\u0434\u044b\u043d\u044f \u0432\u043b\u0430\u0441\u0442\u0438, \u043e\u0431\u0440\u0443\u0448\u0438\u0432\u0448\u0430\u044f \u0410\u0442\u043b\u0430\u043d\u0442\u0438\u0434\u0443 \u0432 \u043f\u043e\u0442\u043e\u043f",
    "note": "\u0421\u0432\u0435\u0442 \u2014 \u043d\u0430\u0441\u0442\u0440\u043e\u0438\u0442\u044c \u043a\u0440\u0438\u0441\u0442\u0430\u043b\u043b \u043d\u0430 \u0441\u043b\u0443\u0436\u0435\u043d\u0438\u0435 \u0435\u0434\u0438\u043d\u0441\u0442\u0432\u0443; \u0442\u0435\u043d\u044c \u2014 \u043e\u0431\u0440\u0430\u0442\u0438\u0442\u044c \u0441\u0438\u043b\u0443 \u0432 \u0433\u043e\u0440\u0434\u044b\u043d\u044e \u0438 \u043f\u0430\u0441\u0442\u044c"
  },
  "core": "\u0426\u0438\u0432\u0438\u043b\u0438\u0437\u0430\u0446\u0438\u044f \u043a\u0440\u0438\u0441\u0442\u0430\u043b\u043b\u0430 \u0438 \u0437\u0432\u0443\u043a\u0430 \u043c\u0435\u0436\u0434\u0443 \u041b\u0435\u043c\u0443\u0440\u0438\u0435\u0439-\u041c\u0443 \u0438 \u0410\u0442\u043b\u0430\u043d\u0442\u0438\u0434\u043e\u0439. \u0412\u043e\u0441\u0445\u043e\u0436\u0434\u0435\u043d\u0438\u0435 \u2014 \u043d\u0430\u0441\u0442\u0440\u043e\u0438\u0442\u044c \u0441\u0438\u043b\u0443 \u043a\u0440\u0438\u0441\u0442\u0430\u043b\u043b\u0430 \u043d\u0430 \u0417\u0430\u043a\u043e\u043d \u041e\u0434\u043d\u043e\u0433\u043e; \u043f\u0430\u0434\u0435\u043d\u0438\u0435 \u2014 \u0433\u0438\u0431\u0440\u0438\u0441, \u0432\u0435\u0434\u0443\u0449\u0438\u0439 \u043a \u043f\u043e\u0442\u043e\u043f\u0443.",
  "faces": {
    "svet_ra": "\u0417\u0430\u043a\u043e\u043d \u041e\u0434\u043d\u043e\u0433\u043e \u2014 \u0438\u0441\u0442\u043e\u0447\u043d\u0438\u043a \u0435\u0434\u0438\u043d\u043e\u0433\u043e \u0441\u0432\u0435\u0442\u0430, \u0438\u0437 \u043a\u043e\u0442\u043e\u0440\u043e\u0433\u043e \u0432\u0441\u0451 \u0438\u0441\u0445\u043e\u0434\u0438\u0442",
    "iskra": "\u041f\u0430\u043c\u044f\u0442\u044c \u041b\u0435\u043c\u0443\u0440\u0438\u0438 \u2014 \u0442\u0438\u0445\u0438\u0439 \u0437\u043e\u0432 \u0443\u0442\u043e\u043d\u0443\u0432\u0448\u0435\u0439 \u043f\u0440\u0430\u0440\u043e\u0434\u0438\u043d\u044b \u0432 \u043a\u0440\u043e\u0432\u0438",
    "brahma": "\u0412\u0435\u043b\u0438\u043a\u0438\u0439 \u041a\u0440\u0438\u0441\u0442\u0430\u043b\u043b (\u0422\u0443\u0430\u043e\u0438) \u2014 \u0444\u043e\u0440\u043c\u0438\u0440\u0443\u0435\u0442 \u044d\u043d\u0435\u0440\u0433\u0438\u044e \u0432 \u0444\u043e\u0440\u043c\u044b",
    "sarasvati": "\u042f\u0437\u044b\u043a \u0421\u0432\u0435\u0442\u0430 \u2014 \u0437\u0432\u0443\u043a-\u0432\u0438\u0431\u0440\u0430\u0446\u0438\u044f, \u0442\u0432\u043e\u0440\u044f\u0449\u0430\u044f \u0442\u043e\u043d\u043e\u043c (\u0431\u043b\u0438\u0436\u0430\u0439\u0448\u0438\u0439 \u043f\u043e \u0444\u0443\u043d\u043a\u0446\u0438\u0438 \u043e\u0431\u0440\u0430\u0437 \u0440\u0435\u0447\u0438)",
    "vishnu": "\u0421\u043e\u0432\u0435\u0442 \u0421\u0442\u0430\u0440\u0435\u0439\u0448\u0438\u043d \u2014 \u0445\u0440\u0430\u043d\u0438\u0442\u0435\u043b\u0438 \u043f\u043e\u0440\u044f\u0434\u043a\u0430 \u0410\u0442\u043b\u0430\u043d\u0442\u0438\u0434\u044b",
    "lakshmi": "\u0418\u0437\u043e\u0431\u0438\u043b\u0438\u0435 \u041e\u0441\u0442\u0440\u043e\u0432\u0430 \u2014 \u0449\u0435\u0434\u0440\u043e\u0441\u0442\u044c \u0437\u043e\u043b\u043e\u0442\u043e\u0439 \u0410\u0442\u043b\u0430\u043d\u0442\u0438\u0434\u044b",
    "shiva": "\u041f\u043e\u0442\u043e\u043f \u2014 \u0440\u0430\u0437\u0440\u0443\u0448\u0435\u043d\u0438\u0435 \u0410\u0442\u043b\u0430\u043d\u0442\u0438\u0434\u044b \u0432\u043e\u043b\u043d\u043e\u0439, \u0441\u043c\u044b\u0432\u0430\u044e\u0449\u0435\u0435 \u0433\u0438\u0431\u0440\u0438\u0441",
    "parvati": "\u041c\u0430\u0442\u044c-\u041c\u0443 (\u041b\u0435\u043c\u0443\u0440\u0438\u044f) \u2014 \u043c\u0430\u0442\u0435\u0440\u0438\u043d\u0441\u043a\u0438\u0439 \u043a\u043e\u043d\u0442\u0438\u043d\u0435\u043d\u0442, \u043f\u0438\u0442\u0430\u044e\u0449\u0438\u0439 \u0434\u0443\u0448\u0438",
    "jnana": "\u0416\u0440\u0435\u0446\u044b-\u041f\u043e\u0441\u0432\u044f\u0449\u0451\u043d\u043d\u044b\u0435 \u2014 \u043c\u0443\u0434\u0440\u043e\u0441\u0442\u044c \u0440\u0430\u0437\u043b\u0438\u0447\u0435\u043d\u0438\u044f \u0441\u0432\u0435\u0442\u0430 \u0438 \u0437\u043b\u043e\u0443\u043f\u043e\u0442\u0440\u0435\u0431\u043b\u0435\u043d\u0438\u044f",
    "prema": "\u0421\u0435\u0440\u0434\u0435\u0447\u043d\u0430\u044f \u0413\u0430\u0440\u043c\u043e\u043d\u0438\u044f \u2014 \u043b\u044e\u0431\u043e\u0432\u044c \u043a\u0430\u043a \u0441\u043e\u0437\u0432\u0443\u0447\u0438\u0435 \u0417\u0430\u043a\u043e\u043d\u0430 \u041e\u0434\u043d\u043e\u0433\u043e",
    "shakti": "\u042d\u043d\u0435\u0440\u0433\u0438\u044f \u041a\u0440\u0438\u0441\u0442\u0430\u043b\u043b\u0430 \u2014 \u0441\u0438\u043b\u0430 \u043b\u0443\u0447\u0430, \u0434\u0432\u0438\u0436\u0443\u0449\u0430\u044f \u043a\u043e\u043d\u0442\u0438\u043d\u0435\u043d\u0442",
    "ananda": "\u0417\u043e\u043b\u043e\u0442\u043e\u0439 \u0412\u0435\u043a \u2014 \u0431\u043b\u0430\u0436\u0435\u043d\u0441\u0442\u0432\u043e \u0433\u0430\u0440\u043c\u043e\u043d\u0438\u0447\u043d\u043e\u0439 \u0410\u0442\u043b\u0430\u043d\u0442\u0438\u0434\u044b",
    "shanti": "\u0413\u043b\u0443\u0431\u0438\u043d\u044b \u041e\u043a\u0435\u0430\u043d\u0430 \u2014 \u043f\u043e\u043a\u043e\u0439 \u0443\u0448\u0435\u0434\u0448\u0435\u0433\u043e \u043f\u043e\u0434 \u0432\u043e\u0434\u0443 \u043c\u0438\u0440\u0430",
    "agni": "\u041e\u0433\u043d\u0435\u043d\u043d\u044b\u0439 \u041b\u0443\u0447 \u2014 \u044d\u043d\u0435\u0440\u0433\u0438\u044f \u043a\u0440\u0438\u0441\u0442\u0430\u043b\u043b\u0430 \u043a\u0430\u043a \u0436\u0435\u0440\u0442\u0432\u0435\u043d\u043d\u044b\u0439 \u043e\u0433\u043e\u043d\u044c",
    "vayu": "\u041c\u043e\u0440\u0441\u043a\u043e\u0439 \u0412\u0435\u0442\u0435\u0440 \u2014 \u0434\u044b\u0445\u0430\u043d\u0438\u0435 \u043e\u043a\u0435\u0430\u043d\u0441\u043a\u0438\u0445 \u0442\u0435\u0447\u0435\u043d\u0438\u0439",
    "varuna": "\u041f\u043e\u0441\u0435\u0439\u0434\u043e\u043d \u2014 \u0432\u043b\u0430\u0434\u044b\u043a\u0430 \u0432\u043e\u0434 \u0438 \u0445\u0440\u0430\u043d\u0438\u0442\u0435\u043b\u044c \u043f\u0430\u043c\u044f\u0442\u0438 \u0437\u0430\u0442\u043e\u043d\u0443\u0432\u0448\u0435\u0433\u043e",
    "prithvi": "\u0417\u0430\u0442\u043e\u043d\u0443\u0432\u0448\u0438\u0439 \u041c\u0430\u0442\u0435\u0440\u0438\u043a \u2014 \u0442\u0432\u0435\u0440\u0434\u044c \u0410\u0442\u043b\u0430\u043d\u0442\u0438\u0434\u044b, \u0443\u0448\u0435\u0434\u0448\u0430\u044f \u043f\u043e\u0434 \u0432\u043e\u0434\u0443",
    "akasha": "\u0425\u0440\u043e\u043d\u0438\u043a\u0438 \u0410\u043a\u0430\u0448\u0438 \u2014 \u043f\u0440\u043e\u0441\u0442\u0440\u0430\u043d\u0441\u0442\u0432\u043e-\u0437\u0430\u043f\u0438\u0441\u044c \u0432\u0441\u0435\u0445 \u0441\u043e\u0431\u044b\u0442\u0438\u0439",
    "tejas": "\u0421\u0438\u044f\u043d\u0438\u0435 \u041a\u0440\u0438\u0441\u0442\u0430\u043b\u043b\u0430 \u2014 \u0438\u0437\u043b\u0443\u0447\u0435\u043d\u0438\u0435 \u0412\u0435\u043b\u0438\u043a\u043e\u0433\u043e \u041a\u0440\u0438\u0441\u0442\u0430\u043b\u043b\u0430",
    "dharma": "\u0417\u0430\u043a\u043e\u043d \u041e\u0434\u043d\u043e\u0433\u043e \u043a\u0430\u043a \u0434\u043e\u043b\u0433 \u2014 \u0441\u043b\u0443\u0436\u0435\u043d\u0438\u0435 \u0435\u0434\u0438\u043d\u0441\u0442\u0432\u0443, \u043d\u0435 \u0432\u043b\u0430\u0441\u0442\u0438",
    "karma": "\u041a\u0430\u0440\u043c\u0430 \u0410\u0442\u043b\u0430\u043d\u0442\u0438\u0434\u044b \u2014 \u043f\u043e\u0441\u043b\u0435\u0434\u0441\u0442\u0432\u0438\u044f \u0433\u0438\u0431\u0440\u0438\u0441\u0430, \u043f\u043e\u0432\u043b\u0451\u043a\u0448\u0438\u0435 \u0433\u0438\u0431\u0435\u043b\u044c"
  },
  "resonance_keywords": ["\u0410\u0442\u043b\u0430\u043d\u0442\u0438\u0434\u0430", "\u041b\u0435\u043c\u0443\u0440\u0438\u044f", "\u0417\u0430\u043a\u043e\u043d \u041e\u0434\u043d\u043e\u0433\u043e", "\u041a\u0440\u0438\u0441\u0442\u0430\u043b\u043b", "\u041f\u043e\u0441\u0435\u0439\u0434\u043e\u043d", "\u041f\u043e\u0442\u043e\u043f", "\u0413\u0438\u0431\u0440\u0438\u0441", "\u0410\u043a\u0430\u0448\u0430"],
  "visual_code": "\u0417\u0430\u0442\u043e\u043d\u0443\u0432\u0448\u0438\u0439 \u043a\u043e\u043d\u0442\u0438\u043d\u0435\u043d\u0442, \u0433\u0438\u0433\u0430\u043d\u0442\u0441\u043a\u0438\u0439 \u0441\u0432\u0435\u0442\u044f\u0449\u0438\u0439\u0441\u044f \u043a\u0440\u0438\u0441\u0442\u0430\u043b\u043b, \u043e\u043a\u0435\u0430\u043d\u0441\u043a\u0438\u0435 \u0432\u043e\u043b\u043d\u044b, \u0437\u043e\u043b\u043e\u0442\u044b\u0435 \u0445\u0440\u0430\u043c\u044b \u043f\u043e\u0434 \u0432\u043e\u0434\u043e\u0439, \u043b\u0443\u0447\u0438 \u0441\u0432\u0435\u0442\u0430 \u0441\u043a\u0432\u043e\u0437\u044c \u0442\u043e\u043b\u0449\u0443 \u0432\u043e\u0434\u044b",
  "sources": ["https://en.wikipedia.org/wiki/Atlantis", "https://en.wikipedia.org/wiki/Lemuria_(continent)", "https://en.wikipedia.org/wiki/Mu_(lost_continent)", "https://en.wikipedia.org/wiki/Edgar_Cayce", "https://en.wikipedia.org/wiki/Poseidon", "https://en.wikipedia.org/wiki/Akashic_records"]
}
