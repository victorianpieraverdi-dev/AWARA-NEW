  "chakra_accent": "\u0421\u0432\u0430\u0434\u0445\u0438\u0441\u0442\u0445\u0430\u043d\u0430",
  "guna_accent": "\u0441\u0430\u0442\u0442\u0432\u0430",
  "graha_accent": "\u041b\u0443\u043d\u0430",
  "pole": {
    "toward": "\u0414\u0430\u043e \u2014 \u0442\u0435\u0447\u044c \u0432 \u0441\u043e\u0433\u043b\u0430\u0441\u0438\u0438 \u0441 \u0435\u0441\u0442\u0435\u0441\u0442\u0432\u0435\u043d\u043d\u044b\u043c \u043f\u0443\u0442\u0451\u043c, \u0443-\u0432\u044d\u0439, \u0441\u0432\u043e\u0431\u043e\u0434\u043d\u044b\u0439 \u0442\u043e\u043a \u0446\u0438 \u0438 \u0433\u0430\u0440\u043c\u043e\u043d\u0438\u044f \u0418\u043d\u044c \u0438 \u042f\u043d",
    "away": "\u0417\u0430\u0441\u0442\u043e\u0439 \u0446\u0438 \u2014 \u043d\u0430\u0441\u0438\u043b\u0438\u0435 \u043d\u0430\u0434 \u0435\u0441\u0442\u0435\u0441\u0442\u0432\u043e\u043c, \u0441\u043a\u043e\u0432\u0430\u043d\u043d\u043e\u0441\u0442\u044c, \u0440\u0430\u0437\u043b\u0430\u0434 \u0418\u043d\u044c \u0438 \u042f\u043d \u0438 \u043e\u0442\u043f\u0430\u0434\u0435\u043d\u0438\u0435 \u043e\u0442 \u0414\u0430\u043e",
    "note": "\u0421\u0432\u0435\u0442 \u2014 \u0441\u043b\u0435\u0434\u043e\u0432\u0430\u0442\u044c \u0414\u0430\u043e \u0447\u0435\u0440\u0435\u0437 \u043d\u0435\u0434\u0435\u044f\u043d\u0438\u0435 \u0438 \u0441\u0432\u043e\u0431\u043e\u0434\u043d\u044b\u0439 \u0442\u043e\u043a \u0446\u0438; \u0442\u0435\u043d\u044c \u2014 \u043d\u0430\u0441\u0438\u043b\u043e\u0432\u0430\u0442\u044c \u0435\u0441\u0442\u0435\u0441\u0442\u0432\u043e, \u043a\u043e\u043f\u0438\u0442\u044c \u0437\u0430\u0441\u0442\u043e\u0439 \u0438 \u0442\u0435\u0440\u044f\u0442\u044c \u0440\u0430\u0432\u043d\u043e\u0432\u0435\u0441\u0438\u0435"
  },
  "core": "\u041b\u0438\u043d\u0437\u0430 \u0414\u0430\u043e \u0438 \u0437\u0430\u0441\u0442\u043e\u044f \u0446\u0438: \u043c\u0438\u0440 \u2014 \u0432\u0435\u0447\u043d\u043e\u0435 \u0442\u0435\u0447\u0435\u043d\u0438\u0435 \u0414\u0430\u043e \u0438 \u0438\u0433\u0440\u0430 \u0418\u043d\u044c \u0438 \u042f\u043d; \u0432\u043e\u0441\u0445\u043e\u0436\u0434\u0435\u043d\u0438\u0435 \u2014 \u043e\u0441\u0432\u043e\u0431\u043e\u0434\u0438\u0442\u044c \u0442\u043e\u043a \u0446\u0438, \u0432\u0435\u0440\u043d\u0443\u0442\u044c\u0441\u044f \u043a \u0435\u0441\u0442\u0435\u0441\u0442\u0432\u0443 \u0438 \u0442\u0435\u0447\u044c \u0432 \u0441\u043e\u0433\u043b\u0430\u0441\u0438\u0438 \u0441 \u041f\u0443\u0442\u0451\u043c.",
  "faces": {
    "svet_ra": "\u0414\u0430\u043e \u2014 \u0431\u0435\u0437\u044b\u043c\u044f\u043d\u043d\u044b\u0439 \u0438\u0441\u0442\u043e\u043a, \u0438\u0437 \u043a\u043e\u0442\u043e\u0440\u043e\u0433\u043e \u0440\u043e\u0436\u0434\u0430\u0435\u0442\u0441\u044f \u0432\u0441\u0451 \u0441\u0443\u0449\u0435\u0435",
    "iskra": "\u0427\u0430\u043d\u044a\u044d \u2014 \u043b\u0443\u043d\u043d\u0430\u044f \u0431\u043e\u0433\u0438\u043d\u044f, \u0441\u0435\u0440\u0435\u0431\u0440\u044f\u043d\u044b\u0439 \u0441\u0432\u0435\u0442 \u0438 \u0437\u043e\u0432 \u0432 \u043d\u043e\u0447\u0438",
    "brahma": "\u041f\u0430\u043d\u044c\u0433\u0443 \u2014 \u043f\u0435\u0440\u0432\u043e\u0447\u0435\u043b\u043e\u0432\u0435\u043a, \u0440\u0430\u0437\u0434\u0435\u043b\u0438\u0432\u0448\u0438\u0439 \u0445\u0430\u043e\u0441 \u0438 \u0434\u0430\u0432\u0448\u0438\u0439 \u043c\u0438\u0440\u0443 \u0444\u043e\u0440\u043c\u0443",
    "sarasvati": "\u0412\u044d\u043d\u044c\u0447\u0430\u043d \u2014 \u0431\u043e\u0433 \u0441\u043b\u043e\u0432\u0435\u0441\u043d\u043e\u0441\u0442\u0438, \u043f\u0438\u0441\u044c\u043c\u0430 \u0438 \u043a\u0440\u0430\u0441\u043d\u043e\u0440\u0435\u0447\u0438\u044f",
    "vishnu": "\u041d\u0435\u0444\u0440\u0438\u0442\u043e\u0432\u044b\u0439 \u0418\u043c\u043f\u0435\u0440\u0430\u0442\u043e\u0440 \u2014 \u0432\u0435\u0440\u0445\u043e\u0432\u043d\u044b\u0439 \u043f\u0440\u0430\u0432\u0438\u0442\u0435\u043b\u044c \u043d\u0435\u0431\u0435\u0441, \u0445\u0440\u0430\u043d\u044f\u0449\u0438\u0439 \u043c\u0438\u0440\u043e\u043f\u043e\u0440\u044f\u0434\u043e\u043a",
    "lakshmi": "\u0426\u0430\u0439-\u0448\u044d\u043d\u044c \u2014 \u0431\u043e\u0433 \u0431\u043e\u0433\u0430\u0442\u0441\u0442\u0432\u0430, \u0443\u0434\u0430\u0447\u0438 \u0438 \u0438\u0437\u043e\u0431\u0438\u043b\u0438\u044f",
    "shiva": "\u0413\u0443\u043d-\u0433\u0443\u043d \u2014 \u0434\u0443\u0445 \u0445\u0430\u043e\u0441\u0430 \u0432\u043e\u0434, \u043e\u0431\u0440\u0443\u0448\u0438\u0432\u0448\u0438\u0439 \u043d\u0435\u0431\u0435\u0441\u043d\u044b\u0439 \u0441\u0442\u043e\u043b\u043f, \u0440\u0430\u0437\u0440\u0443\u0448\u0435\u043d\u0438\u0435",
    "parvati": "\u0421\u0438\u0432\u0430\u043d\u043c\u0443 \u2014 \u0426\u0430\u0440\u0438\u0446\u0430-\u041c\u0430\u0442\u044c \u0417\u0430\u043f\u0430\u0434\u0430, \u0445\u0440\u0430\u043d\u0438\u0442\u0435\u043b\u044c\u043d\u0438\u0446\u0430 \u0431\u0435\u0441\u0441\u043c\u0435\u0440\u0442\u0438\u044f \u0438 \u0437\u0430\u0431\u043e\u0442\u0430",
    "jnana": "\u041b\u0430\u043e-\u0446\u0437\u044b \u2014 \u043c\u0443\u0434\u0440\u0435\u0446 \u0414\u0430\u043e, \u043f\u0440\u043e\u0437\u0440\u0435\u043d\u0438\u0435 \u0438 \u0440\u0430\u0437\u043b\u0438\u0447\u0435\u043d\u0438\u0435 \u0441\u043e\u043a\u0440\u043e\u0432\u0435\u043d\u043d\u043e\u0433\u043e",
    "prema": "\u042e\u044d-\u043b\u0430\u043e \u2014 \u0441\u0442\u0430\u0440\u0435\u0446 \u043f\u043e\u0434 \u043b\u0443\u043d\u043e\u0439, \u0431\u043e\u0433 \u043b\u044e\u0431\u0432\u0438 \u0438 \u0431\u0440\u0430\u0447\u043d\u044b\u0445 \u0443\u0437, \u0432\u044f\u0436\u0443\u0449\u0438\u0439 \u043a\u0440\u0430\u0441\u043d\u0443\u044e \u043d\u0438\u0442\u044c",
    "shakti": "\u041b\u044d\u0439-\u0433\u0443\u043d \u2014 \u0431\u043e\u0433 \u0433\u0440\u043e\u043c\u0430, \u0441\u0438\u043b\u0430 \u0438 \u043d\u0435\u0431\u0435\u0441\u043d\u0430\u044f \u043a\u0430\u0440\u0430",
    "ananda": "\u0412\u043e\u0441\u0435\u043c\u044c \u0411\u0435\u0441\u0441\u043c\u0435\u0440\u0442\u043d\u044b\u0445 \u2014 \u0440\u0430\u0434\u043e\u0441\u0442\u044c \u0438 \u0431\u043b\u0430\u0436\u0435\u043d\u0441\u0442\u0432\u043e \u0434\u0430\u043e\u0441\u0441\u043a\u043e\u0433\u043e \u043e\u0441\u0432\u043e\u0431\u043e\u0436\u0434\u0435\u043d\u0438\u044f",
    "shanti": "\u0423-\u0432\u044d\u0439 \u2014 \u043f\u043e\u043a\u043e\u0439 \u043d\u0435\u0434\u0435\u044f\u043d\u0438\u044f, \u0431\u0435\u0437\u043c\u044f\u0442\u0435\u0436\u043d\u043e\u0441\u0442\u044c \u0432 \u0441\u043e\u0433\u043b\u0430\u0441\u0438\u0438 \u0441 \u0414\u0430\u043e",
    "agni": "\u0427\u0436\u0443\u0436\u0443\u043d \u2014 \u0431\u043e\u0433 \u043e\u0433\u043d\u044f, \u0441\u0432\u044f\u0449\u0435\u043d\u043d\u043e\u0435 \u043f\u043b\u0430\u043c\u044f \u0438 \u0436\u0430\u0440 \u0436\u0438\u0437\u043d\u0438",
    "vayu": "\u0424\u044d\u043d-\u0431\u043e \u2014 \u043f\u043e\u0432\u0435\u043b\u0438\u0442\u0435\u043b\u044c \u0432\u0435\u0442\u0440\u0430, \u0434\u044b\u0445\u0430\u043d\u0438\u0435 \u0438 \u0434\u0432\u0438\u0436\u0435\u043d\u0438\u0435 \u0446\u0438",
    "varuna": "\u041b\u0443\u043d-\u0432\u0430\u043d \u2014 \u0414\u0440\u0430\u043a\u043e\u043d\u044c\u0438 \u0446\u0430\u0440\u0438 \u043c\u043e\u0440\u0441\u043a\u0438\u0445 \u0432\u043e\u0434, \u0433\u043b\u0443\u0431\u0438\u043d\u0430 \u0438 \u043f\u0430\u043c\u044f\u0442\u044c",
    "prithvi": "\u0425\u043e\u0443\u0442\u0443 \u2014 \u0431\u043e\u0436\u0435\u0441\u0442\u0432\u043e \u0437\u0435\u043c\u043b\u0438, \u0442\u0432\u0435\u0440\u0434\u044c \u0438 \u043e\u043f\u043e\u0440\u0430 \u043c\u0438\u0440\u0430",
    "akasha": "\u0423\u0446\u0437\u0438 \u2014 \u0411\u0435\u0441\u043f\u0440\u0435\u0434\u0435\u043b\u044c\u043d\u043e\u0435, \u0438\u0437\u043d\u0430\u0447\u0430\u043b\u044c\u043d\u0430\u044f \u043f\u0443\u0441\u0442\u043e\u0442\u0430 \u0438 \u043f\u0440\u043e\u0441\u0442\u043e\u0440",
    "tejas": "\u0421\u0438-\u0445\u044d \u2014 \u043c\u0430\u0442\u044c \u0441\u043e\u043b\u043d\u0446, \u0432\u043e\u0437\u043d\u0438\u0446\u0430 \u0441\u0432\u0435\u0442\u0438\u043b\u0430, \u0441\u0438\u044f\u043d\u0438\u0435 \u0434\u043d\u044f",
    "dharma": "\u0413\u0443\u0430\u043d\u044c-\u0434\u0438 \u2014 \u0431\u043e\u0433 \u0432\u0435\u0440\u043d\u043e\u0441\u0442\u0438, \u0441\u043f\u0440\u0430\u0432\u0435\u0434\u043b\u0438\u0432\u043e\u0441\u0442\u0438 \u0438 \u0434\u043e\u043b\u0433\u0430",
    "karma": "\u042f\u043d\u044c\u043b\u043e-\u0432\u0430\u043d \u2014 \u0432\u043b\u0430\u0434\u044b\u043a\u0430 \u0437\u0430\u0433\u0440\u043e\u0431\u043d\u043e\u0433\u043e \u0441\u0443\u0434\u0430, \u0432\u043e\u0437\u0434\u0430\u044f\u043d\u0438\u0435 \u0434\u0435\u044f\u043d\u0438\u0439"
  },
  "resonance_keywords": ["\u0414\u0430\u043e", "\u0418\u043d\u044c-\u042f\u043d", "\u0446\u0438", "\u0443-\u0432\u044d\u0439", "\u0422\u0430\u0439\u0446\u0437\u0438", "\u0431\u0435\u0441\u0441\u043c\u0435\u0440\u0442\u043d\u044b\u0435", "\u0414\u044d", "\u0435\u0441\u0442\u0435\u0441\u0442\u0432\u043e", "\u043f\u044f\u0442\u044c \u0441\u0442\u0438\u0445\u0438\u0439", "\u043f\u043e\u0442\u043e\u043a"],
  "visual_code": "\u0441\u0438\u043c\u0432\u043e\u043b \u0418\u043d\u044c-\u042f\u043d, \u0442\u0435\u043a\u0443\u0449\u0430\u044f \u0432\u043e\u0434\u0430 \u0438 \u0433\u043e\u0440\u044b \u0432 \u0442\u0443\u043c\u0430\u043d\u0435, \u0431\u0430\u043c\u0431\u0443\u043a \u0438 \u0436\u0443\u0440\u0430\u0432\u043b\u0438, \u0432\u043e\u0441\u0435\u043c\u044c \u0442\u0440\u0438\u0433\u0440\u0430\u043c\u043c \u0431\u0430\u0433\u0443\u0430, \u043d\u0435\u0444\u0440\u0438\u0442\u043e\u0432\u044b\u0435 \u0430\u043c\u0443\u043b\u0435\u0442\u044b, \u0441\u0432\u0438\u0442\u043a\u0438-\u043a\u0430\u043b\u043b\u0438\u0433\u0440\u0430\u0444\u0438\u044f, \u043f\u0435\u0440\u0441\u0438\u043a\u0438 \u0431\u0435\u0441\u0441\u043c\u0435\u0440\u0442\u0438\u044f",
