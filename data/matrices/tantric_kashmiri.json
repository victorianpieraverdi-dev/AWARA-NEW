{"matrix_slug":"tantric_kashmiri","matrix_name":"\u041a\u0430\u0448\u043c\u0438\u0440\u0441\u043a\u0438\u0439 \u0448\u0438\u0432\u0430\u0438\u0437\u043c (\u0422\u0440\u0438\u043a\u0430)","element_accent":"\u042d\u0444\u0438\u0440","chakra_accent":"\u0421\u0430\u0445\u0430\u0441\u0440\u0430\u0440\u0430","guna_accent":"\u0441\u0430\u0442\u0442\u0432\u0430","graha_accent":"\u041b\u0443\u043d\u0430","pole":{"toward":"\u041f\u0440\u0430\u0442\u044c\u044f\u0431\u0445\u0438\u0434\u0436\u043d\u044f \u2014 \u0443\u0437\u043d\u0430\u0432\u0430\u043d\u0438\u0435 \u0441\u0435\u0431\u044f \u043a\u0430\u043a \u0428\u0438\u0432\u044b, \u0441\u0432\u0435\u0442 \u0441\u043e\u0437\u043d\u0430\u043d\u0438\u044f \u0438 \u0431\u043b\u0430\u0436\u0435\u043d\u0441\u0442\u0432\u043e \u0421\u043f\u0430\u043d\u0434\u044b","away":"\u0410\u043d\u0430\u0432\u0430-\u043c\u0430\u043b\u0430 \u2014 \u0438\u0437\u043d\u0430\u0447\u0430\u043b\u044c\u043d\u043e\u0435 \u0441\u0436\u0430\u0442\u0438\u0435, \u0437\u0430\u0431\u0432\u0435\u043d\u0438\u0435 \u0431\u043e\u0436\u0435\u0441\u0442\u0432\u0435\u043d\u043d\u043e\u0441\u0442\u0438 \u0438 \u0434\u0440\u043e\u0431\u043b\u0435\u043d\u0438\u0435 \u0435\u0434\u0438\u043d\u043e\u0433\u043e \u0421\u043e\u0437\u043d\u0430\u043d\u0438\u044f \u043d\u0430 \u044d\u0433\u043e","note":"\u0421\u0432\u0435\u0442 \u2014 \u0443\u0437\u043d\u0430\u0442\u044c \u0432\u0441\u0451 \u043a\u0430\u043a \u0432\u0438\u0431\u0440\u0430\u0446\u0438\u044e \u0421\u043e\u0437\u043d\u0430\u043d\u0438\u044f \u0438 \u0440\u0430\u0441\u0448\u0438\u0440\u0438\u0442\u044c \u0441\u0435\u0440\u0434\u0446\u0435; \u0442\u0435\u043d\u044c \u2014 \u0441\u0436\u0430\u0442\u044c\u0441\u044f \u0432 \u043c\u0430\u043b\u044b \u0438 \u043f\u0440\u0438\u043d\u044f\u0442\u044c \u043e\u0433\u0440\u0430\u043d\u0438\u0447\u0435\u043d\u0438\u0435 \u0437\u0430 \u0441\u0435\u0431\u044f"},"core":"\u041d\u0435\u0434\u0432\u043e\u0439\u0441\u0442\u0432\u0435\u043d\u043d\u043e\u0435 \u0421\u043e\u0437\u043d\u0430\u043d\u0438\u0435-\u0428\u0438\u0432\u0430 \u0438 \u0421\u0438\u043b\u0430-\u0428\u0430\u043a\u0442\u0438 \u043d\u0435\u0440\u0430\u0437\u0434\u0435\u043b\u0438\u043c\u044b; \u0432\u0441\u0435\u043b\u0435\u043d\u043d\u0430\u044f \u2014 \u0441\u0432\u043e\u0431\u043e\u0434\u043d\u043e\u0435 \u0441\u0430\u043c\u043e-\u043f\u0440\u043e\u044f\u0432\u043b\u0435\u043d\u0438\u0435 \u0421\u043e\u0437\u043d\u0430\u043d\u0438\u044f, \u0438\u0433\u0440\u0430 \u0441\u0436\u0430\u0442\u0438\u044f \u0438 \u0440\u0430\u0441\u043a\u0440\u044b\u0442\u0438\u044f. \u0412\u043e\u0441\u0445\u043e\u0436\u0434\u0435\u043d\u0438\u0435 \u2014 \u0443\u0437\u043d\u0430\u0432\u0430\u043d\u0438\u0435 \u0441\u0435\u0431\u044f \u043a\u0430\u043a \u043f\u0443\u043b\u044c\u0441\u0438\u0440\u0443\u044e\u0449\u0435\u0433\u043e \u0421\u0432\u0435\u0442\u0430 \u0447\u0435\u0440\u0435\u0437 36 \u0442\u0430\u0442\u0442\u0432 \u0438 \u0432\u0445\u043e\u0434 \u0432 \u0421\u0435\u0440\u0434\u0446\u0435.","faces":{"svet_ra":"\u041f\u0430\u0440\u0430\u043c\u0430\u0448\u0438\u0432\u0430 \u2014 \u0432\u044b\u0441\u0448\u0438\u0439 \u0421\u0432\u0435\u0442-\u0421\u043e\u0437\u043d\u0430\u043d\u0438\u0435, \u043d\u0435\u0434\u0432\u043e\u0439\u0441\u0442\u0432\u0435\u043d\u043d\u044b\u0439 \u0438\u0441\u0442\u043e\u043a","iskra":"\u0410\u043d\u0443\u0442\u0442\u0430\u0440\u0430 \u2014 \u043d\u0435\u0432\u044b\u0440\u0430\u0437\u0438\u043c\u044b\u0439 \u0410\u0431\u0441\u043e\u043b\u044e\u0442, \u0431\u0435\u0437\u043c\u043e\u043b\u0432\u043d\u044b\u0439 \u0438\u0441\u0442\u043e\u043a \u044d\u043c\u0430\u043d\u0430\u0446\u0438\u0438","brahma":"\u0421\u043f\u0430\u043d\u0434\u0430 \u2014 \u0441\u0432\u044f\u0449\u0435\u043d\u043d\u0430\u044f \u0432\u0438\u0431\u0440\u0430\u0446\u0438\u044f, \u043f\u0443\u043b\u044c\u0441 \u0421\u043e\u0437\u043d\u0430\u043d\u0438\u044f, \u0440\u0430\u0437\u0432\u043e\u0440\u0430\u0447\u0438\u0432\u0430\u044e\u0449\u0438\u0439 \u043c\u0438\u0440","sarasvati":"\u041c\u0430\u0442\u0440\u0438\u043a\u0430 \u2014 \u043c\u0430\u0442\u044c-\u0437\u0432\u0443\u043a, \u044d\u043d\u0435\u0440\u0433\u0438\u044f \u0430\u043b\u0444\u0430\u0432\u0438\u0442\u0430, \u0440\u043e\u0436\u0434\u0430\u044e\u0449\u0430\u044f \u0440\u0435\u0447\u044c \u0438 \u043c\u0438\u0440\u044b","vishnu":"\u0421\u0430\u0434\u0430\u0448\u0438\u0432\u0430 \u2014 \u0443\u0440\u043e\u0432\u0435\u043d\u044c \u00ab\u042f \u0435\u0441\u043c\u044c \u044d\u0442\u043e\u00bb, \u0445\u0440\u0430\u043d\u044f\u0449\u0438\u0439 \u0444\u043e\u0440\u043c\u0443 \u0442\u0432\u043e\u0440\u0435\u043d\u0438\u044f","lakshmi":"\u0410\u0431\u0445\u0430\u0441\u0430 \u2014 \u0441\u0430\u043c\u043e-\u043f\u0440\u043e\u044f\u0432\u043b\u0435\u043d\u0438\u0435, \u0441\u0438\u044f\u044e\u0449\u0435\u0435 \u0438\u0437\u043e\u0431\u0438\u043b\u0438\u0435 \u0444\u043e\u0440\u043c \u043a\u0430\u043a \u043e\u0442\u0431\u043b\u0435\u0441\u043a \u0421\u0432\u0435\u0442\u0430","shiva":"\u0411\u0445\u0430\u0439\u0440\u0430\u0432\u0430 \u2014 \u0433\u0440\u043e\u0437\u043d\u044b\u0439 \u0428\u0438\u0432\u0430, \u043f\u043e\u0433\u043b\u043e\u0449\u0430\u044e\u0449\u0438\u0439 \u0432\u0441\u0435\u043b\u0435\u043d\u043d\u0443\u044e \u0432 \u0421\u043e\u0437\u043d\u0430\u043d\u0438\u0435","parvati":"\u041f\u0430\u0440\u0430 \u2014 \u0412\u044b\u0441\u0448\u0430\u044f \u0411\u043e\u0433\u0438\u043d\u044f, \u0432\u0435\u0440\u0445\u043e\u0432\u043d\u0430\u044f \u0428\u0430\u043a\u0442\u0438, \u043c\u0430\u0442\u044c \u0442\u0440\u0438\u0430\u0434\u044b \u0438 \u043c\u0438\u043b\u043e\u0441\u0442\u044c","jnana":"\u0414\u0436\u043d\u044f\u043d\u0430-\u0448\u0430\u043a\u0442\u0438 \u2014 \u0441\u0438\u043b\u0430 \u0437\u043d\u0430\u043d\u0438\u044f, \u0440\u0430\u0437\u043b\u0438\u0447\u0435\u043d\u0438\u0435 \u042f \u0438 \u043d\u0435-\u042f","prema":"\u0410\u043d\u0443\u0433\u0440\u0430\u0445\u0430 \u2014 \u043d\u0438\u0441\u0445\u043e\u0434\u044f\u0449\u0430\u044f \u041c\u0438\u043b\u043e\u0441\u0442\u044c, \u043b\u04