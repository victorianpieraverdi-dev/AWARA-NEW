{"matrix_slug":"tarot_arcanic","matrix_name":"\u0422\u0430\u0440\u043e-\u0410\u0440\u043a\u0430\u043d\u0438\u0447\u0435\u0441\u043a\u0430\u044f","element_accent":"\u042d\u0444\u0438\u0440","chakra_accent":"\u0421\u0430\u0445\u0430\u0441\u0440\u0430\u0440\u0430","guna_accent":"\u0441\u0430\u0442\u0442\u0432\u0430","graha_accent":"\u041b\u0443\u043d\u0430","pole":{"toward":"\u0410\u0440\u043a\u0430\u043d \u2014 \u0436\u0438\u0432\u043e\u0439 \u0430\u0440\u0445\u0435\u0442\u0438\u043f, \u043a\u043b\u044e\u0447 \u0441\u0430\u043c\u043e\u043f\u043e\u0437\u043d\u0430\u043d\u0438\u044f \u0438 \u043e\u0441\u043e\u0437\u043d\u0430\u043d\u043d\u044b\u0439 \u043f\u0443\u0442\u044c \u0428\u0443\u0442\u0430 \u043a \u0446\u0435\u043b\u043e\u0441\u0442\u043d\u043e\u0441\u0442\u0438 \u041c\u0438\u0440\u0430","away":"\u0418\u043b\u043b\u044e\u0437\u0438\u044f \u0420\u0430\u0441\u043a\u043b\u0430\u0434\u0430 \u2014 \u0440\u0430\u0431\u0441\u0442\u0432\u043e \u0443 \u0441\u0443\u0434\u044c\u0431\u044b \u0438 \u0414\u044c\u044f\u0432\u043e\u043b\u0430, \u0433\u0430\u0434\u0430\u043d\u0438\u0435 \u0432\u043c\u0435\u0441\u0442\u043e \u0436\u0438\u0437\u043d\u0438","note":"\u0421\u0432\u0435\u0442 \u2014 22 \u0430\u0440\u043a\u0430\u043d\u0430 \u043a\u0430\u043a \u0437\u0435\u0440\u043a\u0430\u043b\u043e \u0434\u0443\u0448\u0438 \u0438 \u043a\u0430\u0440\u0442\u0430 \u043f\u0443\u0442\u0438; \u0442\u0435\u043d\u044c \u2014 \u0444\u0430\u0442\u0430\u043b\u0438\u0437\u043c \u0438 \u043f\u043b\u0435\u043d \u0438\u043b\u043b\u044e\u0437\u0438\u0439"},"core":"22 \u0421\u0442\u0430\u0440\u0448\u0438\u0445 \u0410\u0440\u043a\u0430\u043d\u0430 \u2014 \u043f\u0443\u0442\u044c \u0428\u0443\u0442\u0430 \u043e\u0442 \u0438\u0441\u043a\u0440\u044b \u0434\u043e \u041c\u0438\u0440\u0430. \u041a\u0430\u0436\u0434\u044b\u0439 \u0430\u0440\u043a\u0430\u043d \u2014 \u0436\u0438\u0432\u043e\u0439 \u0430\u0440\u0445\u0435\u0442\u0438\u043f \u0438 \u0441\u0442\u0443\u043f\u0435\u043d\u044c \u043f\u043e\u0441\u