  "pole": {
    "toward": "\u041b\u0430\u0434 \u2014 \u043c\u0438\u0440\u043e\u043f\u043e\u0440\u044f\u0434\u043e\u043a \u041f\u0440\u0430\u0432\u0438, \u0441\u043e\u0433\u043b\u0430\u0441\u0438\u0435 \u0440\u043e\u0434\u0430, \u043f\u0440\u0438\u0440\u043e\u0434\u044b \u0438 \u0431\u043e\u0433\u043e\u0432, \u0436\u0438\u0437\u043d\u044c \u043f\u043e \u043f\u0440\u0430\u0432\u0434\u0435 \u0438 \u0441\u043e\u0432\u0435\u0441\u0442\u0438",
    "away": "\u041c\u043e\u0440\u043e\u043a \u2014 \u043c\u043e\u0440\u043e\u0447\u0430\u0449\u0430\u044f \u0442\u044c\u043c\u0430, \u0440\u0430\u0437\u043b\u0430\u0434 \u0438 \u0437\u0430\u0431\u0432\u0435\u043d\u0438\u0435 \u0440\u043e\u0434\u0430, \u043e\u0442\u043f\u0430\u0434\u0435\u043d\u0438\u0435 \u043e\u0442 \u041f\u0440\u0430\u0432\u0438 \u0432 \u043a\u0440\u0438\u0432\u0434\u0443",
    "note": "\u0421\u0432\u0435\u0442 \u2014 \u0436\u0438\u0442\u044c \u043f\u043e \u041f\u0440\u0430\u0432\u0438, \u0432 \u043b\u0430\u0434\u0443 \u0441 \u0440\u043e\u0434\u043e\u043c, \u0437\u0435\u043c\u043b\u0451\u0439 \u0438 \u043f\u0440\u0435\u0434\u043a\u0430\u043c\u0438; \u0442\u0435\u043d\u044c \u2014 \u0432\u043f\u0430\u0441\u0442\u044c \u0432 \u043c\u043e\u0440\u043e\u043a, \u043a\u0440\u0438\u0432\u0434\u0443 \u0438 \u0437\u0430\u0431\u0432\u0435\u043d\u0438\u0435 \u043a\u043e\u0440\u043d\u0435\u0439"
  },
  "core": "\u041b\u0438\u043d\u0437\u0430 \u041b\u0430\u0434\u0430 \u0438 \u041c\u043e\u0440\u043e\u043a\u0430: \u043c\u0438\u0440 \u2014 \u0436\u0438\u0432\u043e\u0435 \u043a\u043e\u043b\u043e \u041f\u0440\u0430\u0432\u0438, \u042f\u0432\u0438 \u0438 \u041d\u0430\u0432\u0438; \u0432\u043e\u0441\u0445\u043e\u0436\u0434\u0435\u043d\u0438\u0435 \u2014 \u0432\u0435\u0440\u043d\u0443\u0442\u044c \u043b\u0430\u0434 \u0441 \u0440\u043e\u0434\u043e\u043c, \u043f\u0440\u0438\u0440\u043e\u0434\u043e\u0439 \u0438 \u0431\u043e\u0433\u0430\u043c\u0438, \u0438\u0434\u044f \u043f\u0443\u0442\u0451\u043c \u043f\u0440\u0430\u0432\u0434\u044b.",
  "faces": {
    "svet_ra": "\u0420\u043e\u0434 \u2014 \u0432\u0441\u0435\u043e\u0442\u0435\u0446, \u0438\u0441\u0442\u043e\u043a \u0432\u0441\u0435\u0433\u043e \u0441\u0443\u0449\u0435\u0433\u043e, \u0440\u043e\u0434\u043e\u0432\u043e\u0439 \u0441\u0432\u0435\u0442",
    "iskra": "\u0417\u0430\u0440\u044f \u2014 \u0443\u0442\u0440\u0435\u043d\u043d\u044f\u044f \u0437\u0432\u0435\u0437\u0434\u0430, \u0437\u043e\u0432 \u0438 \u0438\u0441\u043a\u0440\u0430 \u0440\u0430\u0441\u0441\u0432\u0435\u0442\u0430",
    "brahma": "\u0421\u0432\u0430\u0440\u043e\u0433 \u2014 \u043d\u0435\u0431\u0435\u0441\u043d\u044b\u0439 \u043a\u0443\u0437\u043d\u0435\u0446, \u0442\u0432\u043e\u0440\u0435\u0446 \u0444\u043e\u0440\u043c \u0438 \u043c\u0438\u0440\u043e\u043f\u043e\u0440\u044f\u0434\u043a\u0430",
    "sarasvati": "\u0412\u0435\u043b\u0435\u0441 \u2014 \u0431\u043e\u0433 \u043c\u0443\u0434\u0440\u043e\u0441\u0442\u0438, \u043f\u0435\u0441\u0435\u043d, \u0441\u043b\u043e\u0432\u0430 \u0438 \u0441\u043a\u0430\u0437\u0430\u043d\u0438\u0439",
    "vishnu": "\u0414\u0430\u0436\u044c\u0431\u043e\u0433 \u2014 \u0441\u043e\u043b\u043d\u0435\u0447\u043d\u044b\u0439 \u043f\u043e\u0434\u0430\u0442\u0435\u043b\u044c \u0431\u043b\u0430\u0433, \u043f\u043e\u0434\u0434\u0435\u0440\u0436\u0430\u043d\u0438\u0435 \u0436\u0438\u0437\u043d\u0438 \u0438 \u0440\u043e\u0434\u0430",
    "lakshmi": "\u0416\u0438\u0432\u0430 \u2014 \u0436\u0438\u0437\u043d\u044c, \u043f\u043b\u043e\u0434\u043e\u0440\u043e\u0434\u0438\u0435 \u0438 \u0438\u0437\u043e\u0431\u0438\u043b\u0438\u0435",
    "shiva": "\u0427\u0435\u0440\u043d\u043e\u0431\u043e\u0433 \u2014 \u0447\u0451\u0440\u043d\u044b\u0439 \u0431\u043e\u0433, \u0440\u0430\u0437\u0440\u0443\u0448\u0435\u043d\u0438\u0435 \u0438 \u0442\u044c\u043c\u0430",
    "parvati": "\u041c\u043e\u043a\u043e\u0448\u044c \u2014 \u043c\u0430\u0442\u044c-\u0437\u0435\u043c\u043b\u044f, \u0437\u0430\u0431\u043e\u0442\u0430, \u043f\u0440\u044f\u0445\u0430 \u0441\u0443\u0434\u0435\u0431 \u0438 \u043f\u043e\u043a\u0440\u043e\u0432\u0438\u0442\u0435\u043b\u044c\u043d\u0438\u0446\u0430 \u0436\u0435\u043d\u0449\u0438\u043d",
    "jnana": "\u0413\u0430\u043c\u0430\u044e\u043d \u2014 \u0432\u0435\u0449\u0430\u044f \u043f\u0442\u0438\u0446\u0430, \u043f\u0440\u043e\u0437\u0440\u0435\u043d\u0438\u0435 \u0438 \u043f\u0440\u043e\u0440\u043e\u0447\u0435\u0441\u043a\u043e\u0435 \u0437\u043d\u0430\u043d\u0438\u0435",
    "prema": "\u041b\u0430\u0434\u0430 \u2014 \u0431\u043e\u0433\u0438\u043d\u044f \u043b\u044e\u0431\u0432\u0438, \u043a\u0440\u0430\u0441\u043e\u0442\u044b, \u0433\u0430\u0440\u043c\u043e\u043d\u0438\u0438 \u0438 \u0432\u0435\u0441\u043d\u044b",
    "shakti": "\u041f\u0435\u0440\u0443\u043d \u2014 \u0433\u0440\u043e\u043c\u043e\u0432\u0435\u0440\u0436\u0435\u0446, \u0441\u0438\u043b\u0430, \u0433\u0440\u043e\u0437\u0430 \u0438 \u0432\u043e\u0438\u043d\u0441\u043a\u0430\u044f \u043c\u043e\u0449\u044c",
    "ananda": "\u042f\u0440\u0438\u043b\u043e \u2014 \u0432\u0435\u0441\u0435\u043d\u043d\u0435\u0435 \u0441\u043e\u043b\u043d\u0446\u0435, \u0441\u0442\u0440\u0430\u0441\u0442\u044c, \u0440\u0430\u0434\u043e\u0441\u0442\u044c \u0438 \u0440\u0430\u0441\u0446\u0432\u0435\u0442 \u0436\u0438\u0437\u043d\u0438",
    "shanti": "\u0418\u0440\u0438\u0439 \u2014 \u043d\u0435\u0431\u0435\u0441\u043d\u044b\u0439 \u0441\u0430\u0434 \u043f\u0440\u0435\u0434\u043a\u043e\u0432, \u043f\u043e\u043a\u043e\u0439 \u0438 \u0431\u043b\u0430\u0436\u0435\u043d\u043d\u044b\u0439 \u043c\u0438\u0440",
    "agni": "\u041e\u0433\u043e\u043d\u044c \u0421\u0432\u0430\u0440\u043e\u0436\u0438\u0447 \u2014 \u0441\u0432\u044f\u0449\u0435\u043d\u043d\u044b\u0439 \u043e\u0433\u043e\u043d\u044c, \u0436\u0435\u0440\u0442\u0432\u0435\u043d\u043d\u043e\u0435 \u043f\u043b\u0430\u043c\u044f \u043e\u0447\u0430\u0433\u0430",
    "vayu": "\u0421\u0442\u0440\u0438\u0431\u043e\u0433 \u2014 \u0431\u043e\u0433 \u0432\u0435\u0442\u0440\u043e\u0432, \u0434\u044b\u0445\u0430\u043d\u0438\u0435 \u0438 \u0434\u0432\u0438\u0436\u0435\u043d\u0438\u0435 \u0432\u043e\u0437\u0434\u0443\u0445\u0430",
    "varuna": "\u041d\u0430\u0432\u044c \u2014 \u043f\u043e\u0434\u0437\u0435\u043c\u043d\u044b\u0439 \u043c\u0438\u0440 \u0432\u043e\u0434, \u0433\u043b\u0443\u0431\u0438\u043d\u0430 \u0438 \u043f\u0430\u043c\u044f\u0442\u044c \u043f\u0440\u0435\u0434\u043a\u043e\u0432",
    "prithvi": "\u041c\u0430\u0442\u044c \u0421\u044b\u0440\u0430 \u0417\u0435\u043c\u043b\u044f \u2014 \u0437\u0435\u043c\u043b\u044f-\u043e\u043f\u043e\u0440\u0430, \u0440\u043e\u0434\u044f\u0449\u0430\u044f \u0442\u0432\u0435\u0440\u0434\u044c",
    "akasha": "\u0421\u0432\u0430\u0440\u0433\u0430 \u2014 \u043d\u0435\u0431\u0435\u0441\u043d\u044b\u0439 \u043f\u0440\u043e\u0441\u0442\u043e\u0440, \u043f\u0440\u043e\u0441\u0442\u0440\u0430\u043d\u0441\u0442\u0432\u043e \u0431\u043e\u0433\u043e\u0432",
    "tejas": "\u0425\u043e\u0440\u0441 \u2014 \u0441\u043e\u043b\u043d\u0435\u0447\u043d\u044b\u0439 \u0434\u0438\u0441\u043a, \u0441\u0438\u044f\u043d\u0438\u0435 \u0441\u0432\u0435\u0442\u0438\u043b\u0430",
    "dharma": "\u041f\u0440\u0430\u0432\u044c \u2014 \u0437\u0430\u043a\u043e\u043d \u043c\u0438\u0440\u043e\u0437\u0434\u0430\u043d\u0438\u044f, \u043f\u0443\u0442\u044c \u043f\u0440\u0430\u0432\u0434\u044b \u0438 \u0434\u043e\u043b\u0433\u0430",
    "karma": "\u0414\u043e\u043b\u044f \u0438 \u041d\u0435\u0434\u043e\u043b\u044f \u2014 \u043d\u0438\u0442\u0438 \u0441\u0443\u0434\u044c\u0431\u044b, \u043f\u0440\u0438\u0447\u0438\u043d\u0430 \u0438 \u0441\u043b\u0435\u0434\u0441\u0442\u0432\u0438\u0435 \u0434\u0435\u044f\u043d\u0438\u0439"
  },
  "resonance_keywords": ["\u041f\u0440\u0430\u0432\u0438", "\u042f\u0432\u044c", "\u041d\u0430\u0432\u044c", "\u0420\u043e\u0434", "\u043a\u043e\u043b\u043e\u0432\u0440\u0430\u0442", "\u041b\u0430\u0434", "\u043f\u0440\u0435\u0434\u043a\u0438", "\u0421\u0432\u0430\u0440\u0433\u0430", "\u043f\u0440\u0430\u0432\u0434\u0430", "\u043a\u043e\u043b\u043e"],
  "visual_code": "\u043a\u043e\u043b\u043e\u0432\u0440\u0430\u0442\u044b \u0438 \u0441\u043e\u043b\u044f\u0440\u043d\u044b\u0435 \u0437\u043d\u0430\u043a\u0438, \u0434\u0443\u0431\u043e\u0432\u044b\u0435 \u0438\u0434\u043e\u043b\u044b, \u043e\u0431\u0435\u0440\u0435\u0433\u0438-\u0432\u044b\u0448\u0438\u0432\u0430\u043d\u043a\u0438, \u0437\u043e\u043b\u043e\u0442\u043e\u0435 \u0441\u043e\u043b\u043d\u0446\u0435 \u0425\u043e\u0440\u0441\u0430, \u0431\u0435\u0440\u0451\u0437\u044b \u0438 \u043a\u0430\u043f\u0438\u0449\u0430, \u041c\u0430\u0442\u044c \u0421\u044b\u0440\u0430 \u0417\u0435\u043c\u043b\u044f, \u0440\u0443\u0448\u043d\u0438\u043a\u0438",
