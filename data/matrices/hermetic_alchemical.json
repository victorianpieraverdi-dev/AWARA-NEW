{"matrix_slug":"hermetic_alchemical","matrix_name":"\u0413\u0435\u0440\u043c\u0435\u0442\u0438\u043a\u043e-\u0410\u043b\u0445\u0438\u043c\u0438\u0447\u0435\u0441\u043a\u0430\u044f","element_accent":"\u041e\u0433\u043e\u043d\u044c","chakra_accent":"\u041c\u0430\u043d\u0438\u043f\u0443\u0440\u0430","guna_accent":"\u0440\u0430\u0434\u0436\u0430\u0441","graha_accent":"\u041c\u0435\u0440\u043a\u0443\u0440\u0438\u0439","pole":{"toward":"\u0412\u0435\u043b\u0438\u043a\u043e\u0435 \u0414\u0435\u043b\u0430\u043d\u0438\u0435 \u2014 \u043e\u0441\u043e\u0437\u043d\u0430\u043d\u043d\u0430\u044f \u0442\u0440\u0430\u043d\u0441\u043c\u0443\u0442\u0430\u0446\u0438\u044f \u0441\u0432\u0438\u043d\u0446\u0430 \u0434\u0443\u0448\u0438 \u0432 \u0437\u043e\u043b\u043e\u0442\u043e \u0434\u0443\u0445\u0430, \u043a\u0430\u043a \u0432\u0432\u0435\u0440\u0445\u0443 \u0442\u0430\u043a \u0438 \u0432\u043d\u0438\u0437\u0443","away":"\u0421\u043b\u0435\u043f\u043e\u0435 \u0437\u043b\u0430\u0442\u043e\u0434\u0435\u043b\u0438\u0435 \u2014 \u043f\u043e\u0433\u043e\u043d\u044f \u0437\u0430 \u043c\u0435\u0442\u0430\u043b\u043b\u043e\u043c \u0438 \u0432\u043b\u0430\u0441\u0442\u044c\u044e, \u043f\u0440\u043e\u0444\u0430\u043d\u0430\u0446\u0438\u044f \u0431\u0435\u0437 \u043f\u0440\u0435\u043e\u0431\u0440\u0430\u0436\u0435\u043d\u0438\u044f \u0441\u0435\u0431\u044f","note":"\u0421\u0432\u0435\u0442 \u2014 \u0430\u043b\u0445\u0438\u043c\u0438\u044f \u043a\u0430\u043a \u043f\u0440\u0435\u043e\u0431\u0440\u0430\u0436\u0435\u043d\u0438\u0435 \u0447\u0435\u043b\u043e\u0432\u0435\u043a\u0430; \u0442\u0435\u043d\u044c \u2014 \u0436\u0430\u0434\u043d\u043e\u0441\u0442\u044c \u0438 \u0431\u0443\u043a\u0432\u0430\u043b\u0438\u0437\u043c \u0431\u0435\u0437 \u0434\u0443\u0445\u0430"},"core":"\u0418\u0437\u0443\u043c\u0440\u0443\u0434\u043d\u0430\u044f \u0441\u043a\u0440\u0438\u0436\u0430\u043b\u044c \u0438 \u0412\u0435\u043b\u0438\u043a\u043e\u0435 \u0414\u0435\u043b\u0430\u043d\u0438\u0435: \u0441\u043e\u043b\u043d