","shiva":"\u041d\u0438\u0433\u0440\u0435\u0434\u043e \u2014 \u0447\u0435\u0440\u043d\u0435\u043d\u0438\u0435, \u0441\u043c\u0435\u0440\u0442\u044c \u0438 \u0433\u043d\u0438\u0435\u043d\u0438\u0435 \u043c\u0430\u0442\u0435\u0440\u0438\u0438","parvati":"Luna-\u0441\u0435\u0440\u0435\u0431\u0440\u043e \u2014 \u043b\u0443\u043d\u043d\u0430\u044f \u0432\u043b\u0430\u0433\u0430 \u0438 \u043f\u0440\u0438\u0451\u043c\u043d\u043e\u0435 \u043d\u0430\u0447\u0430\u043b\u043e","jnana":"Mercurius \u2014 \u0434\u0443\u0445-\u043f\u043e\u0441\u0440\u0435\u0434\u043d\u0438\u043a \u0438 \u043c\u0443\u0434\u0440\u043e\u0441\u0442\u044c \u0444\u0438\u043b\u043e\u0441\u043e\u0444\u043e\u0432","prema":"\u0425\u0438\u043c\u0438\u0447\u0435\u0441\u043a\u0430\u044f \u0441\u0432\u0430\u0434\u044c\u0431\u0430 \u2014 \u0441\u043e\u044e\u0437 \u0421\u043e\u043b\u043d\u0446\u0430 \u0438 \u041b\u0443\u043d\u044b","shakti":"Sulphur \u2014 \u0441\u0435\u0440\u0430, \u0433\u043e\u0440\u044e\u0447\u0430\u044f \u0434\u0443\u0448\u0430 \u0438 \u0430\u043a\u0442\u0438\u0432\u043d\u043e\u0435 \u043d\u0430\u0447\u0430\u043b\u043e","ananda":"\u042d\u043b\u0438\u043a\u0441\u0438\u0440 \u0436\u0438\u0437\u043d\u0438 \u2014 \u0431\u043b\u0430\u0436\u0435\u043d\u0441\u0442\u0432\u043e \u0431\u0435\u0441\u0441\u043c\u0435\u0440\u0442\u0438\u044f \u0438 \u0438\u0441\u0446\u0435\u043b\u0435\u043d\u0438\u044f","shanti":"\u0410\u043b\u044c\u0431\u0435\u0434\u043e \u2014 \u0443\u0431\u0435\u043b\u0435\u043d\u0438\u0435, \u043e\u0447\u0438\u0449\u0435\u043d\u0438\u0435 \u0438 \u043f\u043e\u043a\u043e\u0439 \u043f\u043e\u0441\u043b\u0435 \u0442\u044c\u043c\u044b","agni":"\u0422\u0430\u0439\u043d\u044b\u0439 \u043e\u0433\u043e\u043d\u044c \u2014 \u043a\u0430\u043b\u044c\u0446\u0438\u043d\u0430\u0446\u0438\u044f, \u0447\u0442\u043e \u043f\u043b\u0430\u0432\u0438\u0442 \u0433\u0440\u0443\u0431\u043e\u0435","vayu":"\u0421\u0443\u0431\u043b\u0438\u043c\u0430\u0446\u0438\u044f \u2014 \u0432\u043e\u0437\u0433\u043e\u043d\u0