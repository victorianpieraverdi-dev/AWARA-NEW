  "mapping_algorithm": {
    "steps": [
      {
        "step": 1,
        "action": "collect_all_maps_to_lenses",
        "description": "Собрать все линзы из выбранных веток"
      },
      {
        "step": 2,
        "action": "count_lens_frequency",
        "description": "Подсчитать частоту каждой линзы → ТОП-3 = стартовые линзы"
      },
      {
        "step": 3,
        "action": "collect_axes",
        "description": "Каждая категория → maps_to_axis → подсчитать доминантные оси"
      },
      {
        "step": 4,
        "action": "collect_lokas",
        "description": "Каждая категория → maps_to_loka → определить вертикальный фокус"
      },
      {
        "step": 5,
        "action": "generate_first_quest",
        "description": "Взять TOP-1 линзу + TOP-1 ось → L1 квест из matrix_quests[slug].levels['1']"
      }
    ],
    "pseudocode": "\nfunction buildProfile(selectedBranches) {\n    // Step 1-2: Find starting lenses\n    const lensCounts = {};\n    const axisCounts = {};\n    const lokaCounts = {};\n    \n    selectedBranches.forEach(branch => {\n        (branch.maps_to_lenses || []).forEach(lens => {\n            lensCounts[lens] = (lensCounts[lens] || 0) + 1;\n        });\n        // axis comes from parent category\n        axisCounts[branch.parent_axis] = (axisCounts[branch.parent_axis] || 0) + 1;\n        lokaCounts[branch.parent_loka] = (lokaCounts[branch.parent_loka] || 0) + 1;\n    });\n    \n    // Step 3: Sort by frequency\n    const startLenses = Object.entries(lensCounts)\n        .sort((a,b) => b[1]-a[1])\n        .slice(0, 3)\n        .map(e => e[0]);\n    \n    const dominantAxes = Object.entries(axisCounts)\n        .sort((a,b) => b[1]-a[1])\n        .slice(0, 2)\n        .map(e => e[0]);\n    \n    // Step 4: Generate first quest\n    const firstLens = startLenses[0];\n    const firstQuest = matrixQuests[firstLens].levels['1'][0];\n    \n    return {\n        startLenses,\n        dominantAxes,\n        verticalFocus: Object.entries(lokaCounts).sort((a,b) => b[1]-a[1])[0][0],\n        firstQuest\n    };\n}\n"
  },
  "adaptive_profiling": {
    "title": "Адаптивное профилирование — после онбординга",
    "_comment": "Дополнение: после первого выбора ИИ продолжает уточнять профиль по поведению",
    "signal_sources": [
      "Какие квесты берёт / пропускает",
      "В каких локах проводит время",
      "Какие типы активности предпочитает (do/meditate/observe/reflect/create/study/ritual)",
      "Скорость прохождения уровней по линзам",
      "Баланс верх/низ (высшие vs низшие локи)",
      "Работа с теневыми аспектами"
    ],
    "ai_actions": [
      "Мягко предлагать непрокачанные оси как 'новый вкус'",
      "При перекосе верх/низ — предлагать баланс",
      "Показывать паттерны: 'ты часто выбираешь огненные квесты — хочешь попробовать водное?'",
      "ИИ не оценивает — ИИ отражает"
    ]
  }
